---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyBar from '../components/react/MobileStickyBar.tsx';
import { SITE, MEDIA } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
  jsonLd?: unknown | unknown[];
  stickyBar?: boolean;
  preloadImage?: string;
}
const {
  title,
  description = SITE.description,
  path = '',
  ogImage = MEDIA.hero,
  jsonLd,
  stickyBar = true,
  preloadImage,
} = Astro.props;

const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = SITE.url + path;
const lds = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://static.wixstatic.com" crossorigin />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    {/* Load fonts without blocking render; display=swap keeps text visible meanwhile. */}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Caveat:wght@500;600;700&family=Karla:wght@400;500;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Caveat:wght@500;600;700&family=Karla:wght@400;500;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Caveat:wght@500;600;700&family=Karla:wght@400;500;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    {lds.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    {stickyBar && <MobileStickyBar client:idle />}

    <script is:inline>
      // Ribbon-rule + reveal on scroll (honors prefers-reduced-motion via CSS).
      (function () {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('drawn', 'in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.2 }
        );
        const arm = () =>
          document.querySelectorAll('.ribbon-rule, .reveal').forEach((el) => io.observe(el));
        if (document.readyState !== 'loading') arm();
        else document.addEventListener('DOMContentLoaded', arm);
      })();
    </script>
  </body>
</html>
