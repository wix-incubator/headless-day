---
// Hero — full-bleed background video of cute cows grazing, copy overlaid.
import RibbonRule from './RibbonRule.astro';
import { GRAZING } from '../lib/generatedMedia';
import { wixThumb } from '../lib/site';
// Lightweight AVIF/WebP poster (the LCP element) instead of the raw ~1.8MB PNG.
const poster = wixThumb(GRAZING, 1600, 900, 72);
---
<link rel="preload" as="image" href={poster} fetchpriority="high" />
<section class="hm">
  <div class="hm-bg" aria-hidden="true">
    <video id="hero-video" muted loop playsinline preload="none" poster={poster}
      aria-label="Cute cows grazing gently in a wildflower meadow">
      <source src="/hero-cows.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hm-scrim" aria-hidden="true"></div>

  <div class="hm-content container">
    <div class="hm-text">
      <p class="eyebrow">Hand-tied bouquets · for cows</p>
      <h1 class="display-1" style="margin-bottom:.2rem;">A bouquet for moo.</h1>
      <RibbonRule />
      <p class="lead" style="max-width:32ch;color:var(--color-text);">
        Premium hay, fresh pasture grass, and wildflower grazing mixes — arranged with the reverence of a wedding florist and sent grazing.
      </p>
      <div style="display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.4rem;align-items:center;">
        <a class="btn btn-primary btn-lg" href="/shop">Build a bouquet</a>
        <a class="btn btn-ghost btn-lg" href="/herd">Meet the herd</a>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var v = document.getElementById('hero-video');
      if (!v) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // preload="none" defers the video off the critical path; play() loads + plays it after paint.
      var start = function () { v.play().catch(function () {}); };
      if (document.readyState === 'complete') start();
      else window.addEventListener('load', start, { once: true });
    })();
  </script>
</section>

<style>
  .hm { position: relative; overflow: hidden; display: flex; align-items: center; min-height: calc(100vh - 68px); min-height: calc(100svh - 68px); }
  .hm-bg { position: absolute; inset: 0; z-index: 0; }
  .hm-bg video { width: 100%; height: 100%; object-fit: cover; object-position: center 62%; display: block; background: #EAF0DC; }
  .hm-scrim {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      linear-gradient(180deg, #FBF2DC 0%, rgba(251,242,220,0) 16%),
      radial-gradient(38% 60% at 24% 40%, rgba(251,247,239,.66) 0%, rgba(251,247,239,.26) 46%, rgba(251,247,239,0) 66%),
      linear-gradient(180deg, transparent 88%, var(--color-background) 100%);
  }
  .hm-content { position: relative; z-index: 2; width: 100%; padding-block: clamp(2rem, 6vw, 4rem); }
  .hm-text { max-width: 36rem; }

  @media (max-width: 820px) {
    .hm-scrim {
      background:
        linear-gradient(180deg, rgba(251,247,239,.78) 0%, rgba(251,247,239,.44) 46%, rgba(251,247,239,.08) 74%, var(--color-background) 100%);
    }
    .hm-text { max-width: none; }
  }
</style>
