---
import Layout from '../layouts/Layout.astro';
import RibbonRule from '../components/RibbonRule.astro';
import CartAndSend from '../components/react/CartAndSend.tsx';
---
<Layout title="Cart & Send" path="/cart" description="Review your arrangement, add a gift message, and send it grazing." stickyBar={false}>
  <section class="section--tight">
    <div class="container">
      <p class="eyebrow">Almost there</p>
      <h1 class="display-2">Cart &amp; Send</h1>
      <RibbonRule />
    </div>
  </section>
  <section style="padding-bottom:clamp(3rem,7vw,6rem);">
    <div class="container">
      <!-- Cart state lives in the browser → client:only avoids an empty-state flash (caveat A4) -->
      <CartAndSend client:only="react" />
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 820px) { .cart-grid { grid-template-columns: 1fr !important; } }
</style>
