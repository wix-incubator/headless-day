---
import Layout from "../layouts/Layout.astro";
import { getPass, imgSrc } from "../lib/wix";
import siteImages from "../data/site-images.json";

const pass = await getPass();
const price = pass?.formatted ?? "€9";
const passImg = siteImages.pass ? imgSrc(siteImages.pass, 1000, 750) : "";

const value = [
  ["All seven full city guides", "Tel Aviv, Kyiv, Kraków, Dublin, Miami, Vilnius and São Paulo — every one unlocked."],
  ["Every curated spot", "Not just the two free picks — all six more per city, hand-picked."],
  ["The morning crawl routes", "A walkable order for each city, from first coffee to last bite."],
  ["Best-time tips & local phrases", "When to go and exactly what to order, in the local tongue."],
  ["The downloadable Breakfast Passport", "A single, printable PDF covering every city — yours to keep."],
];
---

<Layout
  title="The All-Access Pass — Sunny Side"
  description="One payment, yours forever. Unlock all seven full city guides, every curated spot, the morning crawl routes and the downloadable Breakfast Passport."
  ogImage={passImg || undefined}
>
  <section class="section" style="padding-top:56px;">
    <div class="wrap">
      <div class="two-col" style="gap:48px;">
        <div>
          <p class="eyebrow">The All-Access Pass</p>
          <h1 style="font-size:clamp(2.4rem,6vw,3.8rem);margin:12px 0 16px;">Every full guide,<br />one warm morning at a time</h1>
          <p style="font-size:1.15rem;max-width:46ch;color:var(--espresso);">
            Sunny Side is free to browse — two great picks in every city. The Pass unlocks the rest: the full crawl, the local know-how, and the Breakfast Passport to take with you.
          </p>

          <div style="display:flex;align-items:baseline;gap:14px;margin:28px 0 8px;">
            <span style="font-family:var(--serif);font-size:clamp(3rem,9vw,4.4rem);color:var(--terracotta);line-height:1;">{price}</span>
            <span class="muted">one-time · yours forever</span>
          </div>
          <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:18px;">
            <button class="btn btn-primary btn-lg" data-buy>Get the Pass — {price}</button>
            <a class="btn btn-ghost btn-lg" href="/cities">Browse the free guides</a>
          </div>
          <p id="buy-error" role="alert" hidden style="color:var(--terracotta);margin-top:14px;font-size:14px;"></p>
          <p class="muted" style="margin-top:16px;font-size:13.5px;">Secure checkout powered by Wix Payments · No subscription, ever.</p>
        </div>

        <div class="reveal">
          <div style="border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:4/3;">
            {passImg
              ? <img src={passImg} alt="A spread of breakfast dishes from around the world" width="1000" height="750" style="width:100%;height:100%;object-fit:cover;" />
              : <div class="tile" style="height:100%;"><span class="tile-label">The Breakfast Passport</span></div>}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE LIST -->
  <section class="section" style="padding-top:8px;">
    <div class="wrap">
      <div class="card reveal" style="padding:40px;max-width:820px;margin:0 auto;">
        <p class="eyebrow">What you get</p>
        <h2 style="font-size:clamp(1.7rem,4vw,2.3rem);margin:8px 0 26px;">Everything in the Pass</h2>
        <ul class="value-list">
          {value.map(([title, desc]) => (
            <li>
              <span class="check" aria-hidden="true">✓</span>
              <span><strong>{title}.</strong> <span class="muted">{desc}</span></span>
            </li>
          ))}
        </ul>
        <div style="margin-top:30px;padding-top:24px;border-top:1px solid var(--line);display:flex;gap:14px;flex-wrap:wrap;align-items:center;">
          <button class="btn btn-primary btn-lg" data-buy>Get the Pass — {price}</button>
          <span class="muted" style="font-size:14px;">One payment. Unlocks every city instantly.</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
