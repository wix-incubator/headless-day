---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "Sunny Side — breakfast, city by city",
  description = "A warm editorial breakfast guide to the cities where Wix has offices. Browse free picks for seven cities, or unlock the full guides with the All-Access Pass.",
  ogImage,
} = Astro.props;

const path = Astro.url.pathname;
const canonical = Astro.url.href;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");

const cities = [
  ["Tel Aviv", "tel-aviv"],
  ["Kyiv", "kyiv"],
  ["Kraków", "krakow"],
  ["Dublin", "dublin"],
  ["Miami", "miami"],
  ["Vilnius", "vilnius"],
  ["São Paulo", "sao-paulo"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Enable scroll-reveal animations only when JS is present. Without this class,
      // .reveal content stays fully visible (no-JS / slow-JS safe, protects Lighthouse).
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#FBF6EF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {ogImage && <link rel="preload" as="image" href={ogImage} fetchpriority="high" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sunny Side" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Load fonts without blocking render (display=swap handles FOUT). */}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>
  </head>
  <body>
    <a href="#main" class="skip-link" style="position:absolute;left:-999px;top:0;background:#fff;padding:10px 16px;border-radius:8px;z-index:100;" onfocus="this.style.left='12px'" onblur="this.style.left='-999px'">Skip to content</a>
    <header class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="brand" aria-label="Sunny Side home">
          <svg class="sun" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="5.5" fill="#F4B942" stroke="#C15F3C" stroke-width="1.5" />
            <g stroke="#C15F3C" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 1.5v2.5M12 20v2.5M1.5 12h2.5M20 12h2.5M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M19.4 4.6l-1.8 1.8M6.4 17.6l-1.8 1.8" />
            </g>
          </svg>
          <span>Sunny Side</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a class="navlink" href="/cities" aria-current={isActive("/cities") ? "page" : undefined}>Cities</a>
          <a class="navlink navlink-crawls" href="/crawls" aria-current={isActive("/crawls") ? "page" : undefined}>Crawls</a>
          <a class="navlink navlink-passport" href="/passport" aria-current={isActive("/passport") ? "page" : undefined}>Passport</a>
          <a class="navlink" href="/pass" aria-current={isActive("/pass") ? "page" : undefined}>The Pass</a>
          <a class="navlink navlink-about" href="/about" aria-current={isActive("/about") ? "page" : undefined}>About</a>
          <a class="btn btn-primary nav-cta" href="/pass">Get the Pass</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <div class="footer-suggest">
          <div>
            <h4>Know a spot we missed?</h4>
            <p class="muted" style="margin:0;font-size:14.5px;">Tell us about your favorite breakfast in any of our seven cities.</p>
          </div>
          <a class="btn btn-primary" href="/suggest">Suggest a spot</a>
        </div>
        <div class="footer-grid">
          <div>
            <a href="/" class="brand" style="margin-bottom:12px;">
              <svg class="sun" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="5.5" fill="#F4B942" stroke="#C15F3C" stroke-width="1.5" />
                <g stroke="#C15F3C" stroke-width="1.5" stroke-linecap="round">
                  <path d="M12 1.5v2.5M12 20v2.5M1.5 12h2.5M20 12h2.5M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M19.4 4.6l-1.8 1.8M6.4 17.6l-1.8 1.8" />
                </g>
              </svg>
              <span>Sunny Side</span>
            </a>
            <p class="muted" style="margin-top:12px;max-width:34ch;">Breakfast, city by city — a guide to great mornings in the cities where Wix has offices.</p>
          </div>
          <div class="footer-links">
            <h4>Cities</h4>
            {cities.map(([name, slug]) => (
              <a href={`/cities/${slug}`}>{name}</a>
            ))}
          </div>
          <div class="footer-links">
            <h4>Explore</h4>
            <a href="/cities">All cities</a>
            <a href="/crawls">Guided crawls</a>
            <a href="/passport">The Breakfast Passport</a>
            <a href="/pass">The All-Access Pass</a>
            <a href="/suggest">Suggest a spot</a>
            <a href="/about">About Sunny Side</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© 2026 Sunny Side. A demo built with Wix Headless.</span>
          <span>Sunny Side — breakfast, city by city.</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Scroll-in reveals — reliable, and can never leave content hidden.
      (function () {
        var els = document.querySelectorAll(".reveal");
        if (!els.length) return;
        var revealAll = function () { els.forEach(function (el) { el.classList.add("in"); }); };
        if (!("IntersectionObserver" in window)) { revealAll(); return; }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
            });
          },
          // Reveal a little before entering the viewport so cards are never caught mid-fade.
          { threshold: 0.05, rootMargin: "0px 0px -6% 0px" }
        );
        els.forEach(function (el) { io.observe(el); });
        // Safety net: if anything hasn't revealed shortly after load, reveal it anyway.
        window.addEventListener("load", function () { setTimeout(revealAll, 1600); });
      })();

      // Pass ownership (client-side unlock for this demo).
      window.SunnySide = {
        hasPass: function () {
          try { return localStorage.getItem("sunnyside_pass") === "1"; } catch (e) { return false; }
        },
        grantPass: function () {
          try { localStorage.setItem("sunnyside_pass", "1"); } catch (e) {}
        },
      };
      (function () {
        if (window.SunnySide.hasPass()) {
          document.querySelectorAll('.locked[data-locked="true"]').forEach(function (el) {
            el.setAttribute("data-locked", "false");
          });
          document.querySelectorAll("[data-passport]").forEach(function (el) {
            el.setAttribute("data-unlocked", "true");
          });
          document.querySelectorAll("[data-pass-owned]").forEach(function (el) { el.hidden = false; });
          document.querySelectorAll("[data-pass-missing]").forEach(function (el) { el.hidden = true; });
        }
      })();

      // Deep-link scroll: honor #hash after lazy sections/images settle (the target's
      // position shifts as below-the-fold content renders, so re-run a couple of times).
      (function () {
        var hash = location.hash;
        if (!hash || hash.length < 2) return;
        var id;
        try { id = decodeURIComponent(hash.slice(1)); } catch (e) { id = hash.slice(1); }
        // Land the section's heading just below the sticky nav (explicit offset —
        // doesn't rely on scroll-margin support/quirks).
        var NAV_OFFSET = 88;
        var go = function () {
          var el = document.getElementById(id);
          if (!el) return;
          var y = el.getBoundingClientRect().top + window.pageYOffset - NAV_OFFSET;
          window.scrollTo(0, y > 0 ? y : 0);
        };
        window.addEventListener("load", function () {
          go(); setTimeout(go, 250); setTimeout(go, 800);
        });
      })();

      // Wire every "Get the Pass" buy button to the checkout route.
      (function () {
        document.querySelectorAll("[data-buy]").forEach(function (btn) {
          btn.addEventListener("click", function (ev) {
            ev.preventDefault();
            if (btn.dataset.loading === "1") return;
            btn.dataset.loading = "1";
            var original = btn.innerHTML;
            btn.innerHTML = "Starting checkout…";
            btn.setAttribute("aria-busy", "true");
            var errEl = document.getElementById("buy-error");
            if (errEl) errEl.hidden = true;
            fetch("/api/checkout", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ origin: window.location.origin }),
            })
              .then(function (r) { return r.json(); })
              .then(function (data) {
                if (data && data.url) { window.location.href = data.url; }
                else { throw new Error((data && data.error) || "Checkout unavailable"); }
              })
              .catch(function (e) {
                btn.dataset.loading = "0";
                btn.innerHTML = original;
                btn.removeAttribute("aria-busy");
                if (errEl) {
                  errEl.textContent = "We couldn't start checkout just now — please try again.";
                  errEl.hidden = false;
                } else {
                  alert("We couldn't start checkout just now — please try again.");
                }
              });
          });
        });
      })();
    </script>
  </body>
</html>
