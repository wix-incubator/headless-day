---
// Wix's `wix-seo-tag` middleware already injects <title>, canonical, og:title/url/type/site_name,
// and twitter:card into <head> at request time (verified via dev-server HTML) — this layout only
// adds what that middleware doesn't provide: the meta description and image-based social tags.
export interface Props {
  description: string;
  ogImage?: string;
}
const { description, ogImage = '/og-image.png' } = Astro.props;
const absoluteOgImage = new URL(ogImage, Astro.site);
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={absoluteOgImage} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteOgImage} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
