---
import { BUSINESS, NAV } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="nav-shell sticky top-0 z-60 border-b backdrop-blur"
  style="background:rgba(30,38,16,.94);border-color:rgba(216,210,188,.18)"
>
  <div
    class="mx-auto flex h-16 items-center justify-between gap-4"
    style="max-width:1180px;padding:0 clamp(16px,4vw,40px)"
  >
    <a href="/" class="flex items-center gap-3 no-underline" aria-label={`${BUSINESS.name} home`}>
      <span
        class="inline-flex items-center justify-center"
        style="width:32px;height:32px;background:var(--color-accent);border-radius:50%;color:var(--color-primary);font-family:var(--font-display);font-weight:700;font-size:13px;letter-spacing:0"
        title="Our first build — the old Route 14"
        >{BUSINESS.routeNo}</span
      >
      <span class="hidden sm:block" aria-hidden="true" style="width:1px;height:20px;background:rgba(216,210,188,.3)"></span>
      <span
        class="hidden sm:inline"
        style="font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:2.5px;color:var(--color-on-dark);text-transform:uppercase"
        >{BUSINESS.name}</span
      >
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            style={`font-family:var(--font-display);font-weight:600;font-size:14px;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;color:${isActive(item.href) ? "var(--color-accent)" : "#cdd1bf"}`}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/visit"
        style="font-family:var(--font-display);font-weight:700;font-size:14px;letter-spacing:1.2px;text-transform:uppercase;color:var(--color-primary);background:var(--color-accent);padding:9px 18px;border-radius:4px;text-decoration:none"
        >Book a Saturday</a
      >
    </nav>

    <!-- Mobile: book + menu toggle -->
    <div class="flex items-center gap-2 md:hidden">
      <a
        href="/visit"
        style="font-family:var(--font-display);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;color:var(--color-primary);background:var(--color-accent);padding:8px 14px;border-radius:4px;text-decoration:none"
        >Book</a
      >
      <button
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex h-10 w-10 items-center justify-center rounded"
        style="color:var(--color-on-dark);background:transparent;border:1px solid rgba(216,210,188,.25)"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    hidden
    aria-label="Mobile"
    class="md:hidden"
    style="border-top:1px solid rgba(216,210,188,.14);padding:8px clamp(16px,4vw,40px) 16px"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class="block"
          style="font-family:var(--font-display);font-weight:600;font-size:16px;letter-spacing:1.5px;text-transform:uppercase;color:#cdd1bf;text-decoration:none;padding:12px 0;border-bottom:1px solid rgba(216,210,188,.1)"
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  // Delegated so it keeps working after view-transition page swaps.
  document.addEventListener("click", (e) => {
    const toggle = (e.target as Element)?.closest?.("#nav-toggle") as HTMLElement | null;
    if (!toggle) return;
    const menu = document.getElementById("mobile-menu");
    const open = menu?.hasAttribute("hidden");
    if (open) menu?.removeAttribute("hidden");
    else menu?.setAttribute("hidden", "");
    toggle.setAttribute("aria-expanded", String(!!open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
