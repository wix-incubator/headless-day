---
import { BUSINESS, NAV } from "../data/site";
---
<footer style="background:var(--color-primary);color:#c7c9b6">
  <div
    class="mx-auto grid gap-8"
    style="max-width:1180px;padding:clamp(40px,6vw,68px) clamp(16px,4vw,40px) clamp(96px,12vw,56px);grid-template-columns:repeat(auto-fit,minmax(180px,1fr))"
  >
    <div>
      <div class="mb-3.5 flex items-center gap-3">
        <span
          class="inline-flex items-center justify-center"
          style="width:32px;height:32px;background:var(--color-accent);border-radius:50%;color:var(--color-primary);font-family:var(--font-display);font-weight:700;font-size:13px"
          >{BUSINESS.routeNo}</span
        >
        <span aria-hidden="true" style="width:1px;height:18px;background:rgba(216,210,188,.25)"></span>
        <span style="font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:2px;color:var(--color-on-dark);text-transform:uppercase"
          >{BUSINESS.name}</span
        >
      </div>
      <p style="margin:0;font-size:14px;line-height:1.6;max-width:34ch">
        Decommissioned transit buses, titled as legal motorhomes through Oregon
        DMV. {BUSINESS.city} · est. {BUSINESS.established}.
      </p>
    </div>

    <div>
      <div class="eyebrow mb-3.5" style="color:var(--color-accent)">Visit the shop</div>
      <p style="margin:0;font-size:14px;line-height:1.7">
        {BUSINESS.hours.shop}<br />{BUSINESS.hours.tours}<br />{BUSINESS.hours.closed}
      </p>
    </div>

    <div>
      <div class="eyebrow mb-3.5" style="color:var(--color-accent)">Wander</div>
      <div class="flex flex-col gap-2.5" style="font-size:14px">
        {NAV.map((i) => (
          <a href={i.href} style="color:#c7c9b6;text-decoration:none">{i.label}</a>
        ))}
        <a href="/visit" style="color:#c7c9b6;text-decoration:none">Book a Saturday</a>
      </div>
    </div>

    <div>
      <div class="eyebrow mb-3.5" style="color:var(--color-accent)">Follow</div>
      <div class="flex flex-col gap-2.5" style="font-size:14px">
        <span style="color:#c7c9b6">{BUSINESS.social.instagram}</span>
        <span style="color:#c7c9b6">{BUSINESS.social.secondary}</span>
      </div>
    </div>
  </div>
  <div
    style="border-top:1px solid rgba(216,210,188,.14);padding:18px clamp(16px,4vw,40px);text-align:center;font-size:12px;color:#6f7459;font-family:var(--font-display);letter-spacing:1px;text-transform:uppercase"
  >
    Built in a leaking Portland warehouse since {BUSINESS.established}
  </div>
</footer>
