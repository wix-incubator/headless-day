---
import { PROCESS_STEPS } from "../data/site";
const steps = PROCESS_STEPS;
---
<div class="relative">
  <div
    style="position:absolute;left:clamp(20px,3vw,30px);top:8px;bottom:8px;width:2px;background:repeating-linear-gradient(var(--color-border) 0 8px,transparent 8px 16px)"
  >
  </div>
  <ol class="m-0 flex list-none flex-col p-0" data-reveal-stagger style="gap:clamp(20px,3vw,30px)">
    {
      steps.map((s, i) => {
        const last = i === steps.length - 1;
        return (
          <li class="flex items-start" style="gap:clamp(16px,3vw,28px)">
            <div
              class="flex flex-none items-center justify-center"
              style={`width:clamp(42px,6vw,62px);height:clamp(42px,6vw,62px);border-radius:50%;background:${last ? "var(--color-accent)" : "var(--color-primary)"};color:${last ? "var(--color-primary)" : "var(--color-accent)"};font-family:var(--font-display);font-weight:700;font-size:clamp(17px,2.4vw,24px);box-shadow:0 0 0 6px var(--color-background);z-index:1`}
            >
              {s.n}
            </div>
            <div class="flex-1" style="padding-top:4px">
              <h3 class="display" style="margin:0 0 6px;font-size:clamp(20px,3vw,28px);color:var(--color-text);line-height:1;font-family:var(--font-display);font-weight:700">
                {s.title}
              </h3>
              <p style="margin:0;max-width:58ch;font-size:clamp(15px,1.9vw,18px);line-height:1.55;color:var(--color-primary-soft)">
                {s.body}
              </p>
            </div>
          </li>
        );
      })
    }
  </ol>
</div>
