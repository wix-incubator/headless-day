---
import type { Review } from "../data/site";
interface Props { reviews: Review[]; }
const { reviews } = Astro.props;
---
<section style="background:var(--color-background)">
  <div class="mx-auto" style="max-width:1180px;padding:clamp(54px,9vw,96px) clamp(16px,4vw,40px)">
    <span class="eyebrow" data-reveal="fade" style="color:var(--color-text)">People who signed the title</span>
    <div
      class="grid"
      data-reveal-stagger
      style="grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:clamp(16px,3vw,28px);margin-top:clamp(24px,4vw,40px)"
    >
      {
        reviews.map((r) => (
          <figure
            class="lift"
            style="margin:0;background:var(--color-surface);border:1px solid var(--color-border);border-left:4px solid var(--color-accent);border-radius:8px;padding:clamp(24px,3.5vw,34px)"
          >
            <blockquote class="display" style="margin:0 0 18px;font-size:clamp(20px,2.6vw,27px);line-height:1.25;color:var(--color-text);font-weight:600;text-transform:none;letter-spacing:0">
              “{r.quote}”
            </blockquote>
            <figcaption style="font-size:15px;color:var(--color-text-muted)">
              <strong style="color:var(--color-primary);font-weight:700;font-family:var(--font-display);letter-spacing:.5px">{r.name}</strong>
              {" — "}{r.detail}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
