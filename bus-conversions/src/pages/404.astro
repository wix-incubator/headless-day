---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Off the route — Bus Conversions" description="Page not found.">
  <section style="background:var(--color-primary)">
    <div class="mx-auto text-center" style="max-width:680px;padding:clamp(90px,16vw,170px) clamp(16px,4vw,40px)">
      <div class="display" style="font-size:clamp(72px,18vw,160px);line-height:.8;color:var(--color-accent)">404</div>
      <h1 class="display" style="margin:18px 0 14px;font-size:clamp(26px,5vw,44px);color:var(--color-on-dark)">
        This route's been retired.
      </h1>
      <p style="margin:0 auto 30px;max-width:42ch;font-size:18px;line-height:1.6;color:#c2d29a">
        The page you're looking for doesn't exist — like the #14 line, it stopped
        running. Let's get you back on the map.
      </p>
      <a
        href="/"
        class="inline-block"
        style="font-family:var(--font-display);font-weight:700;letter-spacing:1px;text-transform:uppercase;font-size:16px;color:var(--color-primary);background:var(--color-accent);padding:15px 30px;border-radius:5px;text-decoration:none"
        >Back to the shop →</a
      >
    </div>
  </section>
</Layout>
