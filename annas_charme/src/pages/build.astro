  /* ---------- bracelet SVG preview ---------- */
  function renderBraceletPreview() {
    const preview = $('bead-preview');
    const isMulti = s.type === 'multi';

    if (isMulti) {
      if (!multiPatternReady()) {
        preview.innerHTML = '<span class="text-sm text-neutral-400 italic">Draw a pattern to see the preview…</span>';
        return;
      }
      // Flat loom-style bracelet grid — repeats the 10-col pattern across 30 cols
      const pitch = 9, beadR = 4, cols = 30, rows = s.strandCount;
      const bracW = cols * pitch, bracH = rows * pitch;
      const W = 300, H = Math.max(170, bracH + 40);
      const ox = Math.round((W - bracW) / 2);
      const oy = Math.round((H - bracH) / 2);
      const parts: string[] = [];
      // Cast shadow
      parts.push(`<rect x="${ox}" y="${oy + bracH + 5}" width="${bracW}" height="9" rx="4.5" fill="rgba(0,0,0,0.18)" filter="url(#sfblur)"/>`);
      // Cord/backing band
      parts.push(`<rect x="${ox-5}" y="${oy-4}" width="${bracW+10}" height="${bracH+8}" rx="6" fill="#b8a070" stroke="rgba(0,0,0,0.3)" stroke-width="1"/>`);
      // Bead grid — tile the 10-bead pattern
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const patCol = col % 10;
          const hex = getMultiCellColor(row, patCol) || '#d1d5db';
          const x = (ox + col*pitch + pitch/2).toFixed(1);
          const y = (oy + row*pitch + pitch/2).toFixed(1);
          parts.push(flatBead(x, y, beadR, hex));
        }
      }
      preview.innerHTML = wrapSvgFlat(W, H, parts.join(''));
      return;
    }

    if (s.colors.length === 0) {
      preview.innerHTML = '<span class="text-sm text-neutral-400 italic">Selections will appear here…</span>';
      return;
    }

    const found = s.beadPattern ? BEAD_PATTERNS.find(p => p.name === s.beadPattern) : null;
    const W = 230, H = 230, cx = 115, cy = 115;

    // Single-strand
    const r        = 70;
    const beadR    = 8;
    const isBee    = found?.name === 'Bee';
    const isFlower = found?.name === 'Flower';
    // bee needs 3 consecutive slots; flower can sit tightly; others use 5
    const totalPos = found ? (isBee ? 24 : 20) : 24;
    const patEvery = found ? (isBee ? 8 : isFlower ? 5 : 5) : 0;
    const parts: string[] = [];

    parts.push(`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(0,0,0,0.10)" stroke-width="5.5"/>`);
    parts.push(`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#e0d5c8" stroke-width="3.5"/>`);

    // Collect charm positions
    const charmSlots = new Set<number>();
    if (found) {
      let charmIdx = 0;
      for (let i = 0; i < totalPos; i += patEvery) {
        charmSlots.add(i);
        if (isBee) { charmSlots.add(i - 1); charmSlots.add(i + 1); } // skip neighbors for bee
        const a  = (i / totalPos) * Math.PI * 2 - Math.PI / 2;
        const bx = cx + r * Math.cos(a);
        const by = cy + r * Math.sin(a);
        parts.push(drawCharm(found!.name, bx, by, cx, cy, charmIdx));
        charmIdx++;
      }
    }

    // Letter bead slots — grouped consecutively, centered at bottom of ring
    const letterSlots = new Map<number, string>();
    const lp = s.personal?.kind === 'letters'
      ? s.personal as { kind: 'letters'; value: string; style: 'colorful' | 'black' | 'white' | 'clear' }
      : null;
    if (lp?.value || (lp && lp.decoration !== 'none')) {
      // Build the full bead sequence: decoration chars + letters
      const decoChars: string[] = [];
      if (lp!.decoration === 'heart' || lp!.decoration === 'both') decoChars.push('♥');
      if (lp!.decoration === 'star'  || lp!.decoration === 'both') decoChars.push('★');
      const allBeads = [...decoChars, ...lp!.value.toUpperCase().split('').filter(Boolean)];
      if (allBeads.length > 0) {
        const centerPos = Math.floor(totalPos / 2);
        const startPos  = ((centerPos - Math.floor(allBeads.length / 2)) % totalPos + totalPos) % totalPos;
        allBeads.forEach((ch, i) => {
          let pos = (startPos + i) % totalPos;
          let tries = 0;
          while (charmSlots.has(pos) && tries < totalPos) { pos = (pos + 1) % totalPos; tries++; }
          letterSlots.set(pos, ch);
        });
      }
    }
    const LETTER_COLORS = ['#f43f5e','#a78bfa','#38bdf8','#14b8a6','#fbbf24','#fb923c','#ec4899','#6ee7b7'];

    // Color beads + letter beads (skip charm slots)
    const letterR = 10;
    let colorIdx = 0;
    for (let i = 0; i < totalPos; i++) {
      if (charmSlots.has(i)) continue;
      const a = (i / totalPos) * Math.PI * 2 - Math.PI / 2;
      const x = (cx + r * Math.cos(a)).toFixed(1);
      const y = (cy + r * Math.sin(a)).toFixed(1);
      if (letterSlots.has(i)) {
        const letter = letterSlots.get(i)!;
        const idx = [...letterSlots.keys()].sort((pa, pb) => pa - pb).indexOf(i);
        let fill: string, stroke: string, textColor: string, hlOpacity: number;
        if (lp!.style === 'black') {
          fill = '#111111'; stroke = 'rgba(255,255,255,0.1)'; textColor = '#ffffff'; hlOpacity = 0.18;
        } else if (lp!.style === 'white') {
          fill = '#f4f4f5'; stroke = 'rgba(0,0,0,0.15)'; textColor = '#1a1a1a'; hlOpacity = 0.6;
        } else if (lp!.style === 'clear') {
          fill = 'rgba(186,230,255,0.15)'; stroke = 'rgba(100,180,255,0.45)'; textColor = '#1a1a1a'; hlOpacity = 0.5;
        } else {
          fill = LETTER_COLORS[idx % LETTER_COLORS.length]; stroke = 'rgba(0,0,0,0.1)'; textColor = '#ffffff'; hlOpacity = 0.4;
        }
        const lxf = parseFloat(x), lyf = parseFloat(y);
        const lsp1x = (lxf - letterR*0.28).toFixed(1), lsp1y = (lyf - letterR*0.35).toFixed(1);
        const lclx  = (lxf - letterR*0.38).toFixed(1), lcly  = (lyf - letterR*0.44).toFixed(1);
        parts.push(`<circle cx="${x}" cy="${y}" r="${letterR}" fill="${fill}" stroke="${stroke}" stroke-width="0.8" filter="url(#bshadow)"/>`);
        parts.push(`<circle cx="${x}" cy="${y}" r="${letterR}" fill="url(#rim)" stroke="none"/>`);
        parts.push(`<circle cx="${x}" cy="${y}" r="${letterR}" fill="url(#bshdim)" stroke="none"/>`);
        parts.push(`<text x="${x}" y="${y}" text-anchor="middle" dominant-baseline="central" font-size="9" font-weight="bold" fill="${textColor}" font-family="sans-serif">${letter}</text>`);
        parts.push(`<ellipse cx="${lsp1x}" cy="${lsp1y}" rx="${(letterR*0.20).toFixed(1)}" ry="${(letterR*0.10).toFixed(1)}" fill="white" opacity="0.55" transform="rotate(-35 ${lsp1x} ${lsp1y})"/>`);
        parts.push(`<circle cx="${lclx}" cy="${lcly}" r="${(letterR*0.07).toFixed(1)}" fill="white" opacity="0.85"/>`);
      } else {
        parts.push(beadCircle(x, y, beadR, s.colors[colorIdx++ % s.colors.length]));
      }
    }

    if (found) {
      parts.push(`<text x="${cx}" y="${cy + 5}" text-anchor="middle" dominant-baseline="central" font-size="9" fill="#d1d5db" font-family="sans-serif" letter-spacing="0.5">${found.name.toUpperCase()}</text>`);
    } else if (lp?.value) {
      const styleLabel = lp.style === 'black' ? 'BLACK' : lp.style === 'white' ? 'WHITE' : lp.style === 'clear' ? 'CLEAR' : 'COLORFUL';
      parts.push(`<text x="${cx}" y="${cy + 5}" text-anchor="middle" dominant-baseline="central" font-size="8" fill="#d1d5db" font-family="sans-serif" letter-spacing="0.5">${styleLabel} LETTERS</text>`);
    }

    preview.innerHTML = wrapSvg(W, H, parts.join(''));
  }

  /* ---------- charm dispatcher ---------- */
  function drawCharm(name: string, bx: number, by: number, cx: number, cy: number, charmIdx: number = 0): string {
    switch (name) {
      case 'Cherry':    return cherryCharm(bx, by, cx, cy);
      case 'Flower': {
        const cfg = s.flowerConfigs.length
          ? s.flowerConfigs[charmIdx % s.flowerConfigs.length]
          : { petal: '#f9a8d4', center: '#fbbf24' };
        return flowerCharm(bx, by, cfg.petal, cfg.center);
      }
      case 'Bee':       return beeCharm(bx, by, cx, cy);
      case 'Butterfly': return butterflyCharm(bx, by, cx, cy);
      case 'Pineapple': return pineappleCharm(bx, by, cx, cy);
      case 'Grape':     return grapeCharm(bx, by, cx, cy);
      default: {
        const found = BEAD_PATTERNS.find(p => p.name === name);
        return [
          `<circle cx="${bx.toFixed(1)}" cy="${by.toFixed(1)}" r="11" fill="white" stroke="#e5e7eb" stroke-width="1.5"/>`,
          `<text x="${bx.toFixed(1)}" y="${by.toFixed(1)}" text-anchor="middle" dominant-baseline="central" font-size="13">${found?.emoji ?? '✦'}</text>`,
        ].join('');
      }
    }
  }

  /* ---------- charm shapes (bead-accurate) ---------- */

  // Unit vectors helper
  function outwardVec(bx: number, by: number, cx: number, cy: number) {
    const dx = bx - cx, dy = by - cy, len = Math.sqrt(dx*dx + dy*dy);
    return { ox: dx/len, oy: dy/len, px: -dy/len, py: dx/len }; // outward + perp
  }

  // 🍒 Cherry: green stem bead on cord + 2 red cherry beads outward
  function cherryCharm(bx: number, by: number, cx: number, cy: number): string {
    const { ox, oy, px, py } = outwardVec(bx, by, cx, cy);
    const stemR = 8, cherryR = 8, stemLen = 16, spread = 8;
    const c1x = (bx + ox*stemLen - px*spread).toFixed(1);
    const c1y = (by + oy*stemLen - py*spread).toFixed(1);
    const c2x = (bx + ox*stemLen + px*spread).toFixed(1);
    const c2y = (by + oy*stemLen + py*spread).toFixed(1);
    const bxs = bx.toFixed(1), bys = by.toFixed(1);
    return [
      `<line x1="${bxs}" y1="${bys}" x2="${c1x}" y2="${c1y}" stroke="#15803d" stroke-width="1.5" stroke-linecap="round"/>`,
      `<line x1="${bxs}" y1="${bys}" x2="${c2x}" y2="${c2y}" stroke="#15803d" stroke-width="1.5" stroke-linecap="round"/>`,
      sphere3d(bxs, bys, stemR, '#16a34a'),
      sphere3d(c1x, c1y, cherryR, '#dc2626'),
      sphere3d(c2x, c2y, cherryR, '#dc2626'),
    ].join('');
  }

  // 🌸 Flower: 6 petal beads around a yellow center bead
  function flowerCharm(bx: number, by: number, petalColor: string, centerColor: string): string {
    const petalR = 6, petalDist = 10, centerR = 6;
    const parts: string[] = [];
    for (let i = 0; i < 6; i++) {
      const a  = (i / 6) * Math.PI * 2;
      parts.push(sphere3d((bx + petalDist * Math.cos(a)).toFixed(1), (by + petalDist * Math.sin(a)).toFixed(1), petalR, petalColor, 'rgba(0,0,0,0.12)'));
    }
    parts.push(sphere3d(bx.toFixed(1), by.toFixed(1), centerR, centerColor, 'rgba(0,0,0,0.12)'));
    return parts.join('');
  }

  // 🐝 Bee: 2 white beads on cord + yellow/black/yellow spread outward (like cherry structure)
  function beeCharm(bx: number, by: number, cx: number, cy: number): string {
    const { ox, oy, px, py } = outwardVec(bx, by, cx, cy);
    const r = 8, stemLen = 16, spread = 9, wSp = 7;
    const bxs = bx.toFixed(1), bys = by.toFixed(1);
    // 3 outward beads: yellow(left), black(center), yellow(right)
    const ylx = (bx + ox*stemLen - px*spread).toFixed(1), yly = (by + oy*stemLen - py*spread).toFixed(1);
    const blx = (bx + ox*stemLen).toFixed(1),             bly = (by + oy*stemLen).toFixed(1);
    const yrx = (bx + ox*stemLen + px*spread).toFixed(1), yry = (by + oy*stemLen + py*spread).toFixed(1);
    // 2 white beads on cord (tangential)
    const w1x = (bx - px*wSp).toFixed(1), w1y = (by - py*wSp).toFixed(1);
    const w2x = (bx + px*wSp).toFixed(1), w2y = (by + py*wSp).toFixed(1);
    return [
      `<line x1="${bxs}" y1="${bys}" x2="${ylx}" y2="${yly}" stroke="#c4ae90" stroke-width="1.5" stroke-linecap="round"/>`,
      `<line x1="${bxs}" y1="${bys}" x2="${blx}" y2="${bly}" stroke="#c4ae90" stroke-width="1.5" stroke-linecap="round"/>`,
      `<line x1="${bxs}" y1="${bys}" x2="${yrx}" y2="${yry}" stroke="#c4ae90" stroke-width="1.5" stroke-linecap="round"/>`,
      sphere3d(ylx, yly, r, '#fde047', 'rgba(0,0,0,0.15)'),
      sphere3d(yrx, yry, r, '#fde047', 'rgba(0,0,0,0.15)'),
      sphere3d(blx, bly, r, '#111111', 'rgba(255,255,255,0.1)'),
      sphere3d(w1x, w1y, r, '#f2f2f2', 'rgba(0,0,0,0.15)'),
      sphere3d(w2x, w2y, r, '#f2f2f2', 'rgba(0,0,0,0.15)'),
    ].join('');
  }

  // 🦋 Butterfly: 4 wing beads + small body bead
  function butterflyCharm(bx: number, by: number, cx: number, cy: number): string {
    const { ox, oy, px, py } = outwardVec(bx, by, cx, cy);
    const wingR = 7, bodyR = 5, wDist = 9, wOff = 8;
    const wings = [
      { dx: -px*wDist - ox*wOff, dy: -py*wDist - oy*wOff, color: '#c084fc' },
      { dx:  px*wDist - ox*wOff, dy:  py*wDist - oy*wOff, color: '#c084fc' },
      { dx: -px*(wDist-2) + ox*wOff, dy: -py*(wDist-2) + oy*wOff, color: '#e879f9' },
      { dx:  px*(wDist-2) + ox*wOff, dy:  py*(wDist-2) + oy*wOff, color: '#e879f9' },
    ];
    return [
      ...wings.map(w => sphere3d((bx+w.dx).toFixed(1), (by+w.dy).toFixed(1), wingR, w.color, 'rgba(0,0,0,0.1)')),
      sphere3d(bx.toFixed(1), by.toFixed(1), bodyR, '#7c3aed'),
    ].join('');
  }

  // 🍍 Pineapple: small green crown bead on cord + yellow body bead hanging outward
  function pineappleCharm(bx: number, by: number, cx: number, cy: number): string {
    const { ox, oy } = outwardVec(bx, by, cx, cy);
    const crownR = 6, bodyR = 9, dist = 16;
    const bxs = bx.toFixed(1), bys = by.toFixed(1);
    const bdx = (bx + ox*dist).toFixed(1), bdy = (by + oy*dist).toFixed(1);
    return [
      `<line x1="${bxs}" y1="${bys}" x2="${bdx}" y2="${bdy}" stroke="#15803d" stroke-width="1.2" stroke-linecap="round"/>`,
      sphere3d(bdx, bdy, bodyR, '#fbbf24'),
      sphere3d(bxs, bys, crownR, '#16a34a'),
    ].join('');
  }

  // 🍇 Grape: green stem bead on cord + triangular bunch of purple beads outward
  function grapeCharm(bx: number, by: number, cx: number, cy: number): string {
    const { ox, oy, px, py } = outwardVec(bx, by, cx, cy);
    const grapeR = 6, greenR = 6, sp = 11;
    const parts: string[] = [];
    const bunch = [
      { d: sp,   s: -sp }, { d: sp,   s: 0 }, { d: sp,   s: sp },
      { d: sp*2, s: -sp/2 },                   { d: sp*2, s: sp/2 },
      { d: sp*3, s: 0 },
    ];
    bunch.forEach(({ d, s }) => {
      parts.push(sphere3d((bx+ox*d+px*s).toFixed(1), (by+oy*d+py*s).toFixed(1), grapeR, '#9333ea'));
    });
    parts.push(sphere3d(bx.toFixed(1), by.toFixed(1), greenR, '#16a34a'));
    return parts.join('');
  }

  // Lightweight bead for flat multi-strand grid (no per-bead drop shadow for performance)
  function flatBead(x: string, y: string, r: number, hex: string): string {
    const id = `f${hex.replace(/[^a-f0-9]/gi,'')}`;
    const xf = parseFloat(x), yf = parseFloat(y);
    const holeR = Math.max(1, r * 0.22);
    const hlX = (xf - r*0.25).toFixed(1), hlY = (yf - r*0.3).toFixed(1);
    const hlRx = (r*0.20).toFixed(1), hlRy = (r*0.10).toFixed(1);
    const clx = (xf - r*0.35).toFixed(1), cly = (yf - r*0.38).toFixed(1);
    return [
      `<defs><radialGradient id="${id}" cx="30%" cy="25%" r="72%">`,
      `<stop offset="0%" stop-color="white" stop-opacity="0.65"/>`,
      `<stop offset="22%" stop-color="${hex}"/>`,
      `<stop offset="100%" stop-color="${hex}"/>`,
      `</radialGradient></defs>`,
      `<circle cx="${x}" cy="${y}" r="${r}" fill="url(#${id})" stroke="rgba(0,0,0,0.22)" stroke-width="0.4"/>`,
      `<circle cx="${x}" cy="${y}" r="${r}" fill="url(#rim)" stroke="none"/>`,
      `<circle cx="${x}" cy="${y}" r="${holeR.toFixed(1)}" fill="#111" opacity="0.88"/>`,
      `<ellipse cx="${hlX}" cy="${hlY}" rx="${hlRx}" ry="${hlRy}" fill="white" opacity="0.78" transform="rotate(-35 ${hlX} ${hlY})"/>`,
      `<circle cx="${clx}" cy="${cly}" r="${Math.max(0.5, r*0.08).toFixed(1)}" fill="white" opacity="0.9"/>`,
    ].join('');
  }

  function wrapSvgFlat(w: number, h: number, inner: string) {
    return `<svg viewBox="0 0 ${w} ${h}" width="${w}" height="${h}" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="sfblur" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="6"/>
        </filter>
        <radialGradient id="bshdim" cx="65%" cy="68%" r="55%">
          <stop offset="0%"   stop-color="#000" stop-opacity="0.30"/>
          <stop offset="100%" stop-color="#000" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="rim" cx="50%" cy="50%" r="50%">
          <stop offset="52%" stop-color="#000" stop-opacity="0"/>
          <stop offset="82%" stop-color="#000" stop-opacity="0.22"/>
          <stop offset="100%" stop-color="#000" stop-opacity="0.58"/>
        </radialGradient>
        <radialGradient id="bgsurf" cx="42%" cy="38%" r="70%">
          <stop offset="0%"   stop-color="#fefcf8"/>
          <stop offset="60%"  stop-color="#f5f0ea"/>
          <stop offset="100%" stop-color="#ede5d8"/>
        </radialGradient>
      </defs>
      <rect width="${w}" height="${h}" fill="url(#bgsurf)"/>
      ${inner}
    </svg>`;
  }

  // 3D sphere helper used by charm beads
  function sphere3d(x: string | number, y: string | number, r: number, fill: string, stroke = 'rgba(0,0,0,0.25)'): string {
    const xs = String(x), ys = String(y);
    const xf = parseFloat(xs), yf = parseFloat(ys);
    const sp1x = (xf - r * 0.28).toFixed(1), sp1y = (yf - r * 0.35).toFixed(1);
    const sp1rx = (r * 0.22).toFixed(1), sp1ry = (r * 0.11).toFixed(1);
    const clx = (xf - r * 0.38).toFixed(1), cly = (yf - r * 0.44).toFixed(1);
    const clr = Math.max(0.8, r * 0.07).toFixed(1);
    return [
      `<circle cx="${xs}" cy="${ys}" r="${r}" fill="${fill}" stroke="${stroke}" stroke-width="0.8" filter="url(#bshadow)"/>`,
      `<circle cx="${xs}" cy="${ys}" r="${r}" fill="url(#rim)" stroke="none"/>`,
      `<circle cx="${xs}" cy="${ys}" r="${r}" fill="url(#bshdim)" stroke="none"/>`,
      `<ellipse cx="${sp1x}" cy="${sp1y}" rx="${sp1rx}" ry="${sp1ry}" fill="white" opacity="0.82" transform="rotate(-35 ${sp1x} ${sp1y})"/>`,
      `<circle cx="${clx}" cy="${cly}" r="${clr}" fill="white" opacity="0.95"/>`,
    ].join('');
  }

  function beadCircle(x: string, y: string, r: number, hex: string) {
    const id = `g${hex.replace(/[^a-f0-9]/gi,'')}`;
    const xf = parseFloat(x), yf = parseFloat(y);
    const holeR = r * 0.22;
    const sp1x = (xf - r * 0.28).toFixed(1), sp1y = (yf - r * 0.35).toFixed(1);
    const sp1rx = (r * 0.22).toFixed(1), sp1ry = (r * 0.11).toFixed(1);
    const clx = (xf - r * 0.38).toFixed(1), cly = (yf - r * 0.44).toFixed(1);
    return [
      `<defs><radialGradient id="${id}" cx="30%" cy="25%" r="75%">`,
      `  <stop offset="0%"   stop-color="white" stop-opacity="0.70"/>`,
      `  <stop offset="22%"  stop-color="${hex}" stop-opacity="1"/>`,
      `  <stop offset="100%" stop-color="${hex}"/>`,
      `</radialGradient></defs>`,
      `<circle cx="${x}" cy="${y}" r="${r}" fill="url(#${id})" stroke="rgba(0,0,0,0.22)" stroke-width="0.7" filter="url(#bshadow)"/>`,
      `<circle cx="${x}" cy="${y}" r="${r}" fill="url(#rim)" stroke="none"/>`,
      `<circle cx="${x}" cy="${y}" r="${r}" fill="url(#bshdim)" stroke="none"/>`,
      `<circle cx="${x}" cy="${y}" r="${holeR.toFixed(1)}" fill="#111" opacity="0.88"/>`,
      `<circle cx="${(xf - holeR*0.3).toFixed(1)}" cy="${(yf - holeR*0.3).toFixed(1)}" r="${(holeR*0.4).toFixed(1)}" fill="white" opacity="0.22"/>`,
      `<ellipse cx="${sp1x}" cy="${sp1y}" rx="${sp1rx}" ry="${sp1ry}" fill="white" opacity="0.82" transform="rotate(-35 ${sp1x} ${sp1y})"/>`,
      `<circle cx="${clx}" cy="${cly}" r="${(r*0.07).toFixed(1)}" fill="white" opacity="0.95"/>`,
    ].join('');
  }

  function wrapSvg(w: number, h: number, inner: string) {
    const cx = w / 2, cy = h / 2;
    return `<svg viewBox="0 0 ${w} ${h}" width="${w}" height="${h}" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <!-- Per-bead drop shadow -->
        <filter id="bshadow" x="-80%" y="-80%" width="260%" height="260%">
          <feDropShadow dx="1" dy="3" stdDeviation="3" flood-color="rgba(0,0,0,0.55)"/>
        </filter>
        <!-- Cast shadow blur -->
        <filter id="sfblur" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="9"/>
        </filter>
        <!-- Bottom-right shadow overlay on beads -->
        <radialGradient id="bshdim" cx="65%" cy="68%" r="55%">
          <stop offset="0%"   stop-color="#000" stop-opacity="0.38"/>
          <stop offset="100%" stop-color="#000" stop-opacity="0"/>
        </radialGradient>
        <!-- Edge darkening (rim) — makes every bead look spherical -->
        <radialGradient id="rim" cx="50%" cy="50%" r="50%">
          <stop offset="52%" stop-color="#000" stop-opacity="0"/>
          <stop offset="82%" stop-color="#000" stop-opacity="0.22"/>
          <stop offset="100%" stop-color="#000" stop-opacity="0.60"/>
        </radialGradient>
        <!-- Surface background gradient -->
        <radialGradient id="bgsurf" cx="42%" cy="38%" r="70%">
          <stop offset="0%"   stop-color="#fefcf8"/>
          <stop offset="60%"  stop-color="#f5f0ea"/>
          <stop offset="100%" stop-color="#ede5d8"/>
        </radialGradient>
      </defs>
      <!-- Surface background -->
      <rect width="${w}" height="${h}" fill="url(#bgsurf)"/>
      <!-- Cast shadow under bracelet -->
      <ellipse cx="${cx}" cy="${cy + 9}" rx="84" ry="15" fill="rgba(0,0,0,0.22)" filter="url(#sfblur)"/>
      ${inner}
    </svg>`;
  }

  /* ---------- quantity ---------- */
  function updateQtyDisplay() {
    ($('qty-display') as HTMLElement).textContent = String(s.quantity);
    ($('qty-minus') as HTMLButtonElement).disabled = s.quantity <= 1;
    ($('qty-plus') as HTMLButtonElement).disabled = s.quantity >= 10;
    ($('sum-total') as HTMLElement).textContent = `₪${s.quantity * calcPrice()}`;
  }

  $('qty-minus').addEventListener('click', () => {
    if (s.quantity > 1) { s.quantity--; updateQtyDisplay(); }
  });
  $('qty-plus').addEventListener('click', () => {
    if (s.quantity < 10) { s.quantity++; updateQtyDisplay(); }
  });

  /* ---------- init ---------- */
  setStyleType('single');
</script>
