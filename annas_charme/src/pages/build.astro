  /* ---------- wire Add to Cart ---------- */
  $('next-2').addEventListener('click', async () => {
    const btn = $('next-2') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Adding…';

    try {
      if (!kitProductId) {
        throw new Error('Product info not loaded yet — please try again in a moment.');
      }

      const previewSvg = $('bead-preview').querySelector('svg');
      const previewDataUrl = previewSvg
        ? await svgElementToDataUrl(previewSvg)
        : null;

      const cartItemId = crypto.randomUUID();
      let previewId: string | undefined;
      if (previewDataUrl) {
        previewId = saveCartPreview(cartItemId, previewDataUrl);
      }

      if (s.type) {
        saveStoredCartItem({
          id: cartItemId,
          previewId,
          type: s.type === 'multi' ? 'multi' : 'single',
          strandCount: s.strandCount,
          quantity: s.quantity,
          kitItems: buildKitItems(),
        });
      }

      await fetch('/api/bracelet-clear-diy-wix', {
        method: 'POST',
        credentials: 'same-origin',
      }).catch(() => {});

      showAddedToast();
      resetDesign();
      const wixQty = Number(document.getElementById('cart-modal')?.dataset.wixQty ?? '0');
      updateCartBadge(wixQty);
      renderDiyCartLines();

      btn.disabled = false;
      btn.textContent = 'Add to Cart';
    } catch (e: any) {
      btn.disabled = false;
      btn.textContent = 'Add to Cart';
      alert('Could not add to cart:\n' + (e?.message ?? String(e)));
    }
  });

  /* ---------- personalize — mutually exclusive choice cards ---------- */
  const ACTIVE_CHOICE_CLS  = ['bg-neutral-900','dark:bg-white','text-white','dark:text-black','border-neutral-900','dark:border-white'];
  const INACTIVE_CHOICE_CLS = ['border-neutral-200','dark:border-neutral-700'];

