<!-- GhostLap.astro — the easter egg. Type A-P-E-X anywhere (outside a text
     field) and the boot screen's racing line redraws across the page in
     champagne gold: the line draws itself, a ghost TH-12 laps it, the apex
     ring flares as it crosses, and a timing readout stamps the lap —
     GHOST LAP · 1:07.404. One lap, ~3s, then it's gone. Script-only
     component: listeners bind once per hard load and survive ClientRouter
     swaps; reduced motion never triggers it. -->
<script>
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let buffer = "";
  let running = false;

  // Same normalized corner the boot screen draws, spanned across the viewport.
  const SRC = [
    [-0.08, 0.84],
    [0.38, 0.9],
    [0.64, 0.5],
    [0.88, 0.14],
    [0.96, -0.1],
  ];
  const GOLD = [212, 175, 55] as const;
  const gold = (a: number) => `rgba(${GOLD[0]}, ${GOLD[1]}, ${GOLD[2]}, ${a})`;

  function ghostLap() {
    if (running) return;
    running = true;

    const canvas = document.createElement("canvas");
    canvas.setAttribute("aria-hidden", "true");
    canvas.style.cssText =
      "position:fixed;inset:0;width:100%;height:100%;z-index:80;pointer-events:none;";
    document.body.appendChild(canvas);
    const ctx = canvas.getContext("2d");
    if (!ctx) {
      canvas.remove();
      running = false;
      return;
    }

    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    const w = window.innerWidth;
    const h = window.innerHeight;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const N = 220;
    const q = (a: number, b: number, c: number, t: number) =>
      (1 - t) * (1 - t) * a + 2 * (1 - t) * t * b + t * t * c;
    const cps = SRC.map(([nx, ny]) => [nx * w, ny * h]);
    const pts: number[][] = [];
    for (let i = 0; i <= N; i++) {
      const u = i / N;
      const s = u < 0.5 ? u * 2 : u * 2 - 1;
      pts.push(
        u < 0.5
          ? [q(cps[0][0], cps[1][0], cps[2][0], s), q(cps[0][1], cps[1][1], cps[2][1], s)]
          : [q(cps[2][0], cps[3][0], cps[4][0], s), q(cps[2][1], cps[3][1], cps[4][1], s)],
      );
    }
    // Arc-length midpoint — the flare ring lives at the true center.
    let arc = 0;
    const cum = [0];
    for (let i = 1; i <= N; i++) {
      arc += Math.hypot(pts[i][0] - pts[i - 1][0], pts[i][1] - pts[i - 1][1]);
      cum.push(arc);
    }
    let midIdx = 0;
    while (midIdx < N && cum[midIdx] < arc / 2) midIdx++;
    const MID_U = midIdx / N;

    const DRAW_MS = 1000; // the line redraws itself
    const CAR_T0 = 250; // the ghost launches while the ink is still wet
    const CAR_MS = 1800; // accelerating lap (boot profile: 0.35t + 0.65t²)
    const FADE_T0 = 2300;
    const END = 3000;
    const easeOut = (k: number) => 1 - Math.pow(1 - k, 3);

    function strokeTo(frac: number, alpha: number) {
      const i1 = Math.max(1, Math.min(N, Math.round(frac * N)));
      ctx!.beginPath();
      ctx!.moveTo(pts[0][0], pts[0][1]);
      for (let i = 1; i <= i1; i++) ctx!.lineTo(pts[i][0], pts[i][1]);
      ctx!.lineCap = "round";
      ctx!.lineJoin = "round";
      ctx!.strokeStyle = gold(0.5 * alpha);
      ctx!.lineWidth = 7;
      ctx!.globalAlpha = 0.45;
      ctx!.stroke();
      ctx!.globalAlpha = 1;
      ctx!.strokeStyle = gold(0.85 * alpha);
      ctx!.lineWidth = 1.75;
      ctx!.stroke();
    }

    const t0 = performance.now();
    function frame(now: number) {
      const t = now - t0;
      if (t >= END) {
        canvas.remove();
        running = false;
        return;
      }
      ctx!.clearRect(0, 0, w, h);
      const fade = t > FADE_T0 ? 1 - (t - FADE_T0) / (END - FADE_T0) : 1;
      const drawn = easeOut(Math.min(t / DRAW_MS, 1));
      strokeTo(drawn, fade);

      // The ghost car — the boot's TH-12 silhouette, in gold.
      const k = Math.min(Math.max((t - CAR_T0) / CAR_MS, 0), 1);
      const p = Math.min(k * (0.35 + 0.65 * k), drawn);
      if (k > 0 && k < 1) {
        const hi = Math.max(2, Math.min(N - 2, Math.round(p * N)));
        const ha = pts[hi - 2];
        const hb = pts[hi + 2];
        ctx!.save();
        ctx!.translate(pts[hi][0], pts[hi][1]);
        ctx!.rotate(Math.atan2(hb[1] - ha[1], hb[0] - ha[0]));
        ctx!.scale(1.6, 1.6);
        ctx!.beginPath();
        ctx!.moveTo(-9.4, 1.2);
        ctx!.lineTo(-9.1, -1.3);
        ctx!.lineTo(-10.5, -2.5);
        ctx!.lineTo(-10.15, -2.9);
        ctx!.lineTo(-8.5, -1.58);
        ctx!.quadraticCurveTo(-6.3, -1.75, -5, -1.8);
        ctx!.quadraticCurveTo(-3.7, -3, -2, -3.05);
        ctx!.quadraticCurveTo(-0.6, -3, 0.9, -2.35);
        ctx!.quadraticCurveTo(1.9, -1.85, 3.4, -1.65);
        ctx!.quadraticCurveTo(6, -1.1, 8.4, -0.6);
        ctx!.lineTo(10.1, 0.3);
        ctx!.lineTo(10, 1.2);
        ctx!.lineTo(7, 1.2);
        ctx!.quadraticCurveTo(5.3, -0.75, 3.6, 1.2);
        ctx!.lineTo(-3.2, 1.2);
        ctx!.quadraticCurveTo(-4.9, -0.75, -6.6, 1.2);
        ctx!.closePath();
        const cg = ctx!.createRadialGradient(0, 0, 2, 0, 0, 22);
        cg.addColorStop(0, gold(0.85 * fade));
        cg.addColorStop(1, gold(0));
        ctx!.fillStyle = cg;
        ctx!.fillRect(-24, -24, 48, 48);
        ctx!.fillStyle = `rgba(241, 217, 138, ${0.95 * fade})`;
        ctx!.fill();
        ctx!.restore();
      }

      // Ring flare as the ghost crosses the arc midpoint.
      const [ax, ay] = pts[midIdx];
      if (p > MID_U && p < MID_U + 0.14) {
        const rk = (p - MID_U) / 0.14;
        ctx!.beginPath();
        ctx!.arc(ax, ay, 7 + rk * 80, 0, Math.PI * 2);
        ctx!.strokeStyle = gold((1 - rk) * 0.5 * fade);
        ctx!.lineWidth = 1;
        ctx!.stroke();
      }
      ctx!.beginPath();
      ctx!.arc(ax, ay, 3.5, 0, Math.PI * 2);
      ctx!.fillStyle = gold(0.85 * Math.min(drawn * 2, 1) * fade);
      ctx!.fill();

      // The timing readout stamps once the ghost is through the apex.
      if (p > MID_U + 0.05) {
        const ta = Math.min((p - MID_U - 0.05) / 0.1, 1) * fade;
        ctx!.font = "500 12px 'Inter Variable', Inter, system-ui, sans-serif";
        try {
          (ctx as unknown as { letterSpacing: string }).letterSpacing = "0.3em";
        } catch {}
        ctx!.fillStyle = gold(0.9 * ta);
        ctx!.fillText("GHOST LAP · 1:07.404", ax + 26, ay + 34);
      }

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  if (!reduced) {
    document.addEventListener("keydown", (e) => {
      const el = e.target as HTMLElement | null;
      if (
        el &&
        (el.tagName === "INPUT" ||
          el.tagName === "TEXTAREA" ||
          el.tagName === "SELECT" ||
          el.isContentEditable)
      ) {
        buffer = "";
        return;
      }
      if (e.key.length !== 1) return;
      buffer = (buffer + e.key.toLowerCase()).slice(-4);
      if (buffer === "apex") {
        buffer = "";
        ghostLap();
      }
    });
  }
</script>
