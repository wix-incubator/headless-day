---
// ServiceCard.astro — static card for the sessions listing grid.
// Props in, HTML out; no client-side interactivity. Works for APPOINTMENT and
// CLASS services. Classes (.service-card, .service-card-image,
// .service-card-meta, .service-card-price, …) are owned by
// src/styles/components-bookings.css (pre-copied by the orchestrator).
interface Props {
  id: string;
  slug: string;
  name: string;
  tagLine?: string;
  durationMinutes: number;
  price?: string; // formatted string, e.g. "€349.00" — already formatted by caller
  currency?: string;
  imageUrl?: string;
  videoUrl?: string; // desktop 720p film, played on hover (fades over the still)
  videoUrlMobile?: string; // 480p twin — the page's rendition script picks one
  videoPos?: string; // object-position shared by the still and the film
  type: "APPOINTMENT" | "CLASS";
  locationId?: string; // when a location is selected on the catalog, carry it to the detail page
  locationType?: string;
}

const { slug, name, tagLine, durationMinutes, price, imageUrl, videoUrl, videoUrlMobile, videoPos, locationId, locationType } =
  Astro.props;

// Carry the selected location into the detail page so availability is scoped to it.
const q = new URLSearchParams();
if (locationId) q.set("locationId", locationId);
if (locationType) q.set("locationType", locationType);
const qs = q.toString();
const href = qs ? `/services/${slug}?${qs}` : `/services/${slug}`;
---

<a href={href} class="service-card">
  {
    imageUrl ? (
      <div class="service-card-image">
        <img src={imageUrl} alt={name} loading="lazy" style={videoPos ? `object-position: ${videoPos}` : undefined} />
        {videoUrl && (
          <video
            class="service-card-film"
            data-src-desktop={videoUrl}
            data-src-mobile={videoUrlMobile}
            muted
            loop
            playsinline
            preload="metadata"
            aria-hidden="true"
            style={videoPos ? `object-position: ${videoPos}` : undefined}
          />
        )}
      </div>
    ) : (
      <div
        class="service-card-image service-card-image--placeholder"
        aria-hidden="true"
        style="background-color: var(--color-paper-warm);"
      />
    )
  }

  <div class="service-card-meta">
    <h3 class="service-card-name">{name}</h3>
    {tagLine && <p class="service-card-tagline">{tagLine}</p>}
    <div class="service-card-price">
      <span>{durationMinutes} min</span>
      {price && <span>{price}</span>}
    </div>
  </div>
</a>
