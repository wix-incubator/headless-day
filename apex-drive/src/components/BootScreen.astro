---
// BootScreen.astro — the entry curtain: the racing line draws itself through a
// corner behind the rising APEX wordmark, then the loader hands itself to the
// chrome — the wordmark flies into the header's brand slot (FLIP, measured at
// exit time) while the canvas line morphs its control points onto the
// header's frozen curve and the veil dissolves beneath them; at landing both
// crossfade into the real header elements. Plays once per session on a hard
// load; ClientRouter navigations never re-trigger it (the overlay is
// display:none unless the head script set `html.booting` before first paint).
// Reduced motion skips it entirely, and the head script's watchdog clears it
// even if this module fails. When a hero film is on the page, the curtain
// holds until the hero poster has decoded (3s network failsafe) — the film
// itself attaches after load+idle and never gates the curtain.
const LETTERS = "APEX".split("");
---
<div class="boot" aria-hidden="true">
  <canvas class="boot-canvas" data-boot-canvas></canvas>
  <div class="boot-inner">
    <div class="boot-mark">
      <span class="boot-mask"><span class="boot-tick"></span></span>
      {LETTERS.map((ch, i) => (
        <span class="boot-mask"><span class="boot-letter" style={`--i:${i + 1}`}>{ch}</span></span>
      ))}
    </div>
  </div>
</div>

<script>
  const boot = document.querySelector(".boot") as HTMLElement | null;
  const html = document.documentElement;
  let canvasRaf = 0;
  let beginMorph: (() => void) | null = null;

  function finish() {
    cancelAnimationFrame(canvasRaf);
    html.classList.remove("booting");
    html.classList.remove("boot-landing");
    try {
      sessionStorage.setItem("apex:booted", "1");
    } catch {}
    document.dispatchEvent(new CustomEvent("apex:boot-done"));
  }

  // ── The racing line — corner geometry drawn behind the wordmark. Entry runs
  //    nearly flat along the bottom, the apex flares right of center, the exit
  //    climbs off the top-right. Pointer moves a lerped camera behind the
  //    static type; the pulse laps the corner every ~3.2s. On exit the control
  //    points tween onto the header curve's on-screen geometry so the line
  //    lands exactly on the chrome before the crossfade.
  function startCanvas() {
    const canvas = boot?.querySelector("[data-boot-canvas]") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;

    let w = 0;
    let h = 0;
    let vg: CanvasGradient | null = null; // vignette — rebuilt on resize only
    const resize = () => {
      // DPR capped at 1 — the loader is soft glows and hairlines over a dark
      // veil; extra device pixels are invisible here but multiply the raster
      // cost of every frame (this loop runs during the LCP window).
      const dpr = Math.min(window.devicePixelRatio || 1, 1);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      vg = null;
    };
    new ResizeObserver(resize).observe(canvas);
    resize();

    const N = 220;
    const q = (a: number, b: number, c: number, t: number) =>
      (1 - t) * (1 - t) * a + 2 * (1 - t) * t * b + t * t * c;
    // Normalized loader corner: [entry, control, joint/apex, control, exit].
    const SRC = [
      [-0.08, 0.84],
      [0.38, 0.9],
      [0.64, 0.5],
      [0.88, 0.14],
      [0.96, -0.1],
    ];
    // Kerb ticks mark the geometric corner joint; the hitting circle lives at
    // the arc-length midpoint, computed per frame in draw().
    const apexIdx = Math.round(0.5 * N);

    // Exit morph target — the header curve's control points (same local shape
    // Navigation.astro strokes: 480×122 box at the bar's bottom-left, scaled
    // by --curve-scale) mapped into viewport px. No header curve on screen
    // (mobile hides it) → morphTarget stays null and the line simply fades.
    let morphT0 = 0;
    let morphTarget: number[][] | null = null;
    beginMorph = () => {
      const nav = document.querySelector(".site-nav") as HTMLElement | null;
      const curve = nav?.querySelector(".nav-curve") as HTMLElement | null;
      if (nav && curve && getComputedStyle(curve).display !== "none") {
        const scale = parseFloat(getComputedStyle(nav).getPropertyValue("--curve-scale")) || 1;
        const top = nav.getBoundingClientRect().bottom - 2;
        morphTarget = [
          [0, 44],
          [106, 50],
          [183, 23],
          [245, 2],
          [288, 2],
        ].map(([x, y]) => [x * scale, top + y * scale]);
      }
      morphT0 = performance.now();
    };

    const rand = (min: number, max: number) => min + Math.random() * (max - min);
    const streaks = Array.from({ length: 6 }, () => ({
      y: Math.random(),
      len: rand(0.14, 0.4),
      sp: rand(0.6, 2),
      off: Math.random(),
      a: rand(0.012, 0.04),
      lw: rand(0.75, 1.5),
    }));

    // Pointer-parallax camera — lerped, inverse, canvas-only (type stays put).
    // Eases out during the exit morph so the line lands on a still target.
    let camX = 0;
    let camY = 0;
    let targetX = 0;
    let targetY = 0;
    window.addEventListener("pointermove", (e) => {
      targetX = (e.clientX / window.innerWidth - 0.5) * -26;
      targetY = (e.clientY / window.innerHeight - 0.5) * -16;
    }, { passive: true });

    let pts: number[][] = [];
    const normalAt = (i: number) => {
      const a = pts[Math.max(0, i - 2)];
      const b = pts[Math.min(N, i + 2)];
      const dx = b[0] - a[0];
      const dy = b[1] - a[1];
      const l = Math.hypot(dx, dy) || 1;
      return [-dy / l, dx / l];
    };

    function strokeSegment(from: number, to: number, style: string, width: number, blur = 0, blurColor = "") {
      const i0 = Math.max(0, Math.round(from * N));
      const i1 = Math.min(N, Math.round(to * N));
      if (i1 - i0 < 1) return;
      ctx!.beginPath();
      ctx!.moveTo(pts[i0][0], pts[i0][1]);
      for (let i = i0 + 1; i <= i1; i++) ctx!.lineTo(pts[i][0], pts[i][1]);
      ctx!.lineCap = "round";
      ctx!.lineJoin = "round";
      // Glow as a wide translucent underlay stroke — canvas shadowBlur
      // convolves the whole surface per stroke per frame; this reads the
      // same at a fraction of the cost.
      if (blur > 0 && blurColor) {
        ctx!.strokeStyle = blurColor;
        ctx!.lineWidth = width + blur * 0.8;
        ctx!.globalAlpha = 0.45;
        ctx!.stroke();
        ctx!.globalAlpha = 1;
      }
      ctx!.strokeStyle = style;
      ctx!.lineWidth = width;
      ctx!.stroke();
    }

    const t0 = performance.now();
    function draw(now: number) {
      const t = now - t0;
      ctx!.clearRect(0, 0, w, h);

      // Handoff progress: `fade` retires the set dressing (streaks, edges,
      // kerbs, pulse, vignette); `keep` preserves the line and apex dot when
      // they have a header curve to land on.
      const mRaw = morphT0 ? Math.min((now - morphT0) / 600, 1) : 0;
      const m = mRaw < 0.5 ? 8 * mRaw ** 4 : 1 - (-2 * mRaw + 2) ** 4 / 2;
      const fade = 1 - m;
      const keep = morphTarget ? 1 : fade;

      const mt = morphTarget;
      let cps = SRC.map(([nx, ny]) => [nx * w, ny * h]);
      if (mt && m > 0) {
        cps = cps.map((p, i) => [p[0] + (mt[i][0] - p[0]) * m, p[1] + (mt[i][1] - p[1]) * m]);
      }
      pts = [];
      for (let i = 0; i <= N; i++) {
        const u = i / N;
        const s = u < 0.5 ? u * 2 : u * 2 - 1;
        pts.push(
          u < 0.5
            ? [q(cps[0][0], cps[1][0], cps[2][0], s), q(cps[0][1], cps[1][1], cps[2][1], s)]
            : [q(cps[2][0], cps[3][0], cps[4][0], s), q(cps[2][1], cps[3][1], cps[4][1], s)],
        );
      }
      // Arc-length midpoint — the hitting circle lives at the true center of
      // the drawn line (recomputed per frame so it rides the exit morph and
      // lands on the header curve's own midpoint).
      let arc = 0;
      const cum = [0];
      for (let i = 1; i <= N; i++) {
        arc += Math.hypot(pts[i][0] - pts[i - 1][0], pts[i][1] - pts[i - 1][1]);
        cum.push(arc);
      }
      let midIdx = 0;
      while (midIdx < N && cum[midIdx] < arc / 2) midIdx++;
      const MID_U = midIdx / N;

      camX += (targetX - camX) * 0.06;
      camY += (targetY - camY) * 0.06;
      ctx!.save();
      ctx!.translate(camX * fade, camY * fade);

      if (fade > 0.02) {
        for (const s of streaks) {
          const span = w * (1 + s.len);
          const head = ((s.off + t * 0.00003 * s.sp) % 1) * span;
          const y = s.y * h;
          const len = s.len * w;
          const grad = ctx!.createLinearGradient(head - len, y, head, y);
          grad.addColorStop(0, "rgba(242,240,235,0)");
          grad.addColorStop(0.7, `rgba(242,240,235,${s.a * fade})`);
          grad.addColorStop(1, "rgba(242,240,235,0)");
          ctx!.beginPath();
          ctx!.moveTo(head - len, y);
          ctx!.lineTo(head, y);
          ctx!.strokeStyle = grad;
          ctx!.lineWidth = s.lw;
          ctx!.stroke();
        }

        const EDGE = Math.max(30, h * 0.055);
        for (const side of [-1, 1]) {
          ctx!.beginPath();
          for (let i = 0; i <= N; i++) {
            const [nx, ny] = normalAt(i);
            const ex = pts[i][0] + nx * EDGE * side;
            const ey = pts[i][1] + ny * EDGE * side;
            if (i === 0) ctx!.moveTo(ex, ey);
            else ctx!.lineTo(ex, ey);
          }
          ctx!.strokeStyle = `rgba(242,240,235,${0.05 * fade})`;
          ctx!.lineWidth = 1;
          ctx!.stroke();
        }

        for (let k = -16; k <= 16; k += 4) {
          const i = Math.max(2, Math.min(N - 2, apexIdx + k));
          const [nx, ny] = normalAt(i);
          ctx!.beginPath();
          ctx!.moveTo(pts[i][0] + nx * (EDGE + 4), pts[i][1] + ny * (EDGE + 4));
          ctx!.lineTo(pts[i][0] + nx * (EDGE + 14), pts[i][1] + ny * (EDGE + 14));
          ctx!.strokeStyle = (k / 4) % 2 === 0
            ? `rgba(225,18,31,${0.15 * fade})`
            : `rgba(242,240,235,${0.11 * fade})`;
          ctx!.lineWidth = 3;
          ctx!.stroke();
        }
      }

      // The line thickens toward the header stroke's weight as it lands.
      strokeSegment(0, 1, `rgba(225,18,31,${(0.3 + 0.25 * m) * keep})`, 1.5 + 0.5 * m, 14, `rgba(225,18,31,${0.5 * keep})`);
      if (fade > 0.02) {
        // Same lap pace and speed profile as the header curve (4.8s,
        // pos = 0.35t + 0.65t² — acceleration biting early). The ring
        // window below keys off position, so it fires on the pass as before.
        const lap = (t / 4800) % 1;
        const p = lap * (0.35 + 0.65 * lap);
        // The TH-12 silhouette laps the corner — same simplified shape the
        // header curve carries (spoiler lip, teardrop canopy, splitter,
        // wheel-arch notches). No trail; just the car.
        const glow = `rgba(225,18,31,${0.85 * fade})`;
        const hi = Math.max(2, Math.min(N - 2, Math.round(p * N)));
        const ha = pts[hi - 2];
        const hb = pts[hi + 2];
        ctx!.save();
        ctx!.translate(pts[hi][0], pts[hi][1]);
        ctx!.rotate(Math.atan2(hb[1] - ha[1], hb[0] - ha[0]));
        ctx!.scale(1.6, 1.6);
        ctx!.beginPath();
        ctx!.moveTo(-9.4, 1.2);
        ctx!.lineTo(-9.1, -1.3);
        ctx!.lineTo(-10.5, -2.5);
        ctx!.lineTo(-10.15, -2.9);
        ctx!.lineTo(-8.5, -1.58);
        ctx!.quadraticCurveTo(-6.3, -1.75, -5, -1.8);
        ctx!.quadraticCurveTo(-3.7, -3, -2, -3.05);
        ctx!.quadraticCurveTo(-0.6, -3, 0.9, -2.35);
        ctx!.quadraticCurveTo(1.9, -1.85, 3.4, -1.65);
        ctx!.quadraticCurveTo(6, -1.1, 8.4, -0.6);
        ctx!.lineTo(10.1, 0.3);
        ctx!.lineTo(10, 1.2);
        ctx!.lineTo(7, 1.2);
        ctx!.quadraticCurveTo(5.3, -0.75, 3.6, 1.2);
        ctx!.lineTo(-3.2, 1.2);
        ctx!.quadraticCurveTo(-4.9, -0.75, -6.6, 1.2);
        ctx!.closePath();
        // Glow disc under the car instead of shadowBlur (whole-surface
        // convolution per frame) — at this size they read identically.
        const cg = ctx!.createRadialGradient(0, 0, 2, 0, 0, 22);
        cg.addColorStop(0, glow);
        cg.addColorStop(1, "rgba(225,18,31,0)");
        ctx!.fillStyle = cg;
        ctx!.fillRect(-24, -24, 48, 48);
        ctx!.fillStyle = `rgba(255,92,92,${0.95 * fade})`;
        ctx!.fill();
        ctx!.restore();
        const [ax, ay] = pts[midIdx];
        if (p > MID_U && p < MID_U + 0.14) {
          const k = (p - MID_U) / 0.14;
          ctx!.beginPath();
          ctx!.arc(ax, ay, 7 + k * 80, 0, Math.PI * 2);
          ctx!.strokeStyle = `rgba(225,18,31,${(1 - k) * 0.45 * fade})`;
          ctx!.lineWidth = 1;
          ctx!.stroke();
        }
      }

      ctx!.beginPath();
      ctx!.arc(pts[midIdx][0], pts[midIdx][1], 3.5, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(225,18,31,${(0.85 + 0.05 * m) * keep})`;
      ctx!.fill();

      ctx!.restore();

      if (fade > 0.02) {
        if (!vg) {
          vg = ctx!.createRadialGradient(w * 0.5, h * 0.48, Math.min(w, h) * 0.32, w * 0.5, h * 0.48, Math.max(w, h) * 0.72);
          vg.addColorStop(0, "rgba(10,10,11,0)");
          vg.addColorStop(1, "rgba(10,10,11,0.55)");
        }
        ctx!.globalAlpha = fade;
        ctx!.fillStyle = vg;
        ctx!.fillRect(0, 0, w, h);
        ctx!.globalAlpha = 1;
      }

      canvasRaf = requestAnimationFrame(draw);
    }
    canvasRaf = requestAnimationFrame(draw);
  }

  if (boot && html.classList.contains("booting")) {
    // 350ms of grace before the canvas starts burning main thread — the
    // page's first layout+paint (FCP/LCP, under the veil) and the wordmark
    // rise land in exactly that window; the racing line drawing in a beat
    // behind the letters reads as intentional.
    setTimeout(() => startCanvas(), 350);
    // Start the timeline immediately — the old fonts-race gate (≤800ms) is
    // obsolete now that the latin woff2s are preloaded from <head>; while
    // the curtain is up its own first frame IS the page's FCP/LCP, so every
    // deferred millisecond here was scored. Timeline: rise → hold (gated on
    // the hero POSTER when one is on the page — the film itself attaches
    // after load+idle and must never hold the curtain) → handoff: wordmark
    // flies to the brand slot, line morphs onto the header curve, veil
    // dissolves → landing crossfade → cleanup. The poster gate is failsafed
    // at 3s so a slow network can never hold the page hostage.
    {
      requestAnimationFrame(() => {
        boot.classList.add("boot-play");
        // Deliberate cinematic beat, but the curtain carries Speed Index
        // almost 1:1 — every trimmed 100ms goes straight back to the score
        // and to first-visit patience. Phones (the scored environment) hold
        // 1.5s; desktop keeps the fuller 2s beat.
        const minHold = new Promise((r) =>
          setTimeout(r, matchMedia("(max-width: 767px)").matches ? 1500 : 2000),
        );
        const video = document.querySelector("[data-hero-video]") as HTMLVideoElement | null;
        const posterUrl = video?.getAttribute("poster");
        const posterReady = !posterUrl
          ? Promise.resolve()
          : Promise.race([
              (() => {
                const img = new Image();
                img.src = posterUrl;
                return img.decode().catch(() => {});
              })(),
              new Promise((r) => setTimeout(r, 3000)),
            ]);
        Promise.all([minHold, posterReady]).then(() => {
          // FLIP — measure the flight from the loader mark to the header
          // brand before anything moves; the CSS transition carries it.
          const mark = boot.querySelector(".boot-mark") as HTMLElement | null;
          const brand = document.querySelector(".site-nav .brand-mark") as HTMLElement | null;
          let flight = "";
          if (mark && brand) {
            const s = mark.getBoundingClientRect();
            const d = brand.getBoundingClientRect();
            flight = `translate(${d.left - s.left}px, ${d.top - s.top}px) scale(${d.width / s.width}, ${d.height / s.height})`;
          }
          boot.classList.add("boot-exit");
          beginMorph?.();
          if (mark && flight) {
            requestAnimationFrame(() => {
              mark.style.transform = flight;
            });
          }
          // Landing keyed to the 600ms flight/morph (was 950ms) — the
          // handoff reads snappier without changing its choreography.
          setTimeout(() => html.classList.add("boot-landing"), 600);
          setTimeout(finish, 950);
        });
      });
    }
  } else if (html.classList.contains("booting")) {
    // Markup missing but the flag is set — never leave the page covered.
    finish();
  }
</script>
