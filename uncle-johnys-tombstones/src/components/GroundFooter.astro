---
// A full-bleed band of graveyard ground closing a page. Its top edge fades
// into the void above so it reads as the earth the tombstones stand on.
// Purely decorative — hidden from assistive tech.
---

<img
	class="ground-footer"
	src="/graveyard-ground.webp"
	width="1024"
	height="1024"
	alt=""
	aria-hidden="true"
	loading="lazy"
	decoding="async"
/>

<style>
	.ground-footer {
		display: block;
		width: 100%;
		height: clamp(180px, 28vh, 380px);
		object-fit: cover;
		object-position: center top;
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			#000 55%
		);
		mask-image: linear-gradient(to bottom, transparent 0%, #000 55%);
	}
</style>
