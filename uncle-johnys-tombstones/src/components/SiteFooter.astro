---
// A misty-cemetery image band that fades into the void, sitting above the
// page footer with its authorship credit.
---

<img
	class="cemetery"
	src="/cemetery.webp"
	width="1024"
	height="1024"
	alt="A moonlit cemetery at dusk — a winding path threads between weathered tombstones and bare, twisting trees."
	loading="lazy"
	decoding="async"
/>

<footer class="site-footer">
	<p class="brand">Uncle Johny&rsquo;s Tombstones</p>
	<p class="credit">
		Site created by <span class="author">Vitalii Sashyn</span> using
		<a
			class="wix"
			href="https://www.wix.com/studio/developers/headless"
			target="_blank"
			rel="noopener noreferrer">Wix Headless</a
		>.
	</p>
</footer>

<style>
	.cemetery {
		display: block;
		width: 100%;
		height: clamp(280px, 42vh, 560px);
		object-fit: cover;
		object-position: center 40%;
		/* fade the top edge into the page above and the bottom into the footer */
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			#000 22%,
			#000 82%,
			transparent 100%
		);
		mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			#000 22%,
			#000 82%,
			transparent 100%
		);
	}

	.site-footer {
		padding: clamp(2.5rem, 6vh, 4rem) 1.25rem clamp(3rem, 7vh, 4.5rem);
		margin-top: -6vh;
		text-align: center;
		background: var(--color-void);
		border-top: 1px solid var(--color-border);
	}

	.brand {
		margin: 0 0 0.6rem;
		font-family: var(--font-creepy);
		font-size: clamp(1.1rem, 3vw, 1.6rem);
		letter-spacing: 0.04em;
		color: var(--text-secondary);
		text-shadow: 0 0 18px rgba(45, 212, 191, 0.2);
	}

	.credit {
		margin: 0;
		font-family: var(--font-body);
		font-size: clamp(0.85rem, 2vw, 0.98rem);
		color: var(--text-muted);
	}

	.author {
		color: var(--text-secondary);
	}

	.wix {
		color: var(--color-accent-bright);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.wix:hover {
		color: var(--text-primary);
		border-bottom-color: var(--color-accent-deep);
	}
</style>
