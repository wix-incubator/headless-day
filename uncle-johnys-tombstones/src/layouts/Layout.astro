---
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Client-side routing so the ambient audio (below, transition:persist)
		     keeps playing uninterrupted across route changes -->
		<ClientRouter />
		<meta
			name="description"
			content="Uncle Johny's Tombstones — select your tombstone, and I'll handle the rest."
		/>
		<title>Uncle Johny's Tombstones</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Eater&display=swap"
			rel="stylesheet"
		/>

	</head>
	<body>
		<slot />

		<!-- Ambient soundtrack: "Tiptoe at Midnight", looping across the whole
		     site. transition:persist carries this exact element across
		     client-side route changes (see <ClientRouter/> in the head), so it
		     keeps playing without interruption instead of restarting each page.
		     Browsers block autoplay-with-sound until a user gesture, so we try
		     on load and otherwise start on the first interaction; the on/off
		     choice + playhead are also saved to sessionStorage so a full page
		     reload resumes cleanly. -->
		<audio
			id="ambient-audio"
			src="/tiptoe-at-midnight.mp3"
			loop
			preload="none"
			transition:persist="ambient-audio"></audio>

		<button
			id="sound-toggle"
			class="sound-toggle"
			type="button"
			aria-pressed="true"
			aria-label="Mute background music"
			transition:persist="sound-toggle"
		>
			<svg
				class="ico ico-on"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M11 5 6 9H3v6h3l5 4z" fill="currentColor"></path>
				<path d="M15.5 8.5a5 5 0 0 1 0 7"></path>
				<path d="M18.5 6a9 9 0 0 1 0 12"></path>
			</svg>
			<svg
				class="ico ico-off"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M11 5 6 9H3v6h3l5 4z" fill="currentColor"></path>
				<line x1="16" y1="9" x2="22" y2="15"></line>
				<line x1="22" y1="9" x2="16" y2="15"></line>
			</svg>
		</button>

		<script is:inline>
			(function () {
				var audio = document.getElementById("ambient-audio");
				var toggle = document.getElementById("sound-toggle");
				if (!audio || !toggle) return;

				// Set up once per full page load. Under client-side routing the
				// audio + toggle persist across navigations (transition:persist),
				// so re-running this on each swap would only reset the playhead
				// and double-bind handlers — bail if we've already initialised.
				if (window.__ujAmbientInit) return;
				window.__ujAmbientInit = true;

				var TIME_KEY = "uj-ambient-time";
				var PREF_KEY = "uj-ambient-pref"; // "on" | "off"

				function pref() {
					try {
						return sessionStorage.getItem(PREF_KEY);
					} catch (e) {
						return null;
					}
				}
				function setPref(v) {
					try {
						sessionStorage.setItem(PREF_KEY, v);
					} catch (e) {}
				}
				function saveTime() {
					try {
						sessionStorage.setItem(TIME_KEY, String(audio.currentTime || 0));
					} catch (e) {}
				}

				// resume where the last page left off (looped ~58s track)
				var saved = 0;
				try {
					saved = parseFloat(sessionStorage.getItem(TIME_KEY) || "0") || 0;
				} catch (e) {}
				if (saved > 0) {
					var applyTime = function () {
						try {
							if (isFinite(audio.duration) && audio.duration > 0) {
								audio.currentTime = saved % audio.duration;
							}
						} catch (e) {}
					};
					if (audio.readyState >= 1) applyTime();
					else
						audio.addEventListener("loadedmetadata", applyTime, {
							once: true,
						});
				}

				// on by default; only off if the visitor silenced it this session
				var on = pref() !== "off";

				function reflect() {
					toggle.classList.toggle("is-muted", !on);
					toggle.setAttribute("aria-pressed", on ? "true" : "false");
					toggle.setAttribute(
						"aria-label",
						on ? "Mute background music" : "Play background music"
					);
				}

				// arm one-shot listeners so the score begins on the first gesture
				// when the browser blocks autoplay-with-sound on load
				function armGesture() {
					var evts = ["pointerdown", "keydown", "touchstart"];
					var kick = function () {
						evts.forEach(function (ev) {
							document.removeEventListener(ev, kick);
						});
						if (on) audio.play().catch(function () {});
					};
					evts.forEach(function (ev) {
						document.addEventListener(ev, kick, { passive: true });
					});
				}

				reflect();
				if (on) {
					var p = audio.play();
					if (p && typeof p.catch === "function")
						p.catch(function () {
							armGesture();
						});
				}

				toggle.addEventListener("click", function () {
					on = !on;
					setPref(on ? "on" : "off");
					reflect();
					if (on) {
						audio.play().catch(function () {});
					} else {
						audio.pause();
						saveTime();
					}
				});

				// keep the playhead in sync so the next page resumes seamlessly
				window.addEventListener("pagehide", saveTime);
				document.addEventListener("visibilitychange", function () {
					if (document.visibilityState === "hidden") saveTime();
				});
			})();
		</script>
	</body>
</html>

<style is:global>
	:root {
		/* dark neutrals */
		--color-void: #0d0f12;
		--color-bg: #14171b;
		--color-surface: #1d2126;
		--color-overlay: #282d34;
		--color-border: #333a42;
		--color-ink: #05070a;

		/* twilight */
		--twilight-top: #2a2438;
		--twilight-bottom: #3e2e39;

		/* cyan-green accent */
		--color-accent: #2dd4bf;
		--color-accent-bright: #5eead4;
		--color-accent-deep: #0f766e;
		--color-accent-glow: rgba(94, 234, 212, 0.35);

		/* toxic neon green — the primary action colour */
		--color-toxic: #39ff14;
		--color-toxic-bright: #7dff5f;
		--color-toxic-deep: #1f9e12;
		--color-toxic-glow: rgba(57, 255, 20, 0.4);

		/* text */
		--text-primary: #e7e4d6;
		--text-secondary: #a7ada3;
		--text-muted: #6b7169;

		--font-display: "Cinzel", Georgia, serif;
		--font-body: "Lora", Georgia, "Times New Roman", serif;
		--font-creepy: "Eater", "Cinzel", Georgia, serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: var(--color-void);
		color: var(--text-primary);
		font-family: var(--font-body);
		-webkit-font-smoothing: antialiased;
		/* Uncle Johny lights your way — a carried lantern in place of the arrow.
		   hotspot sits on the top ring so the lantern hangs from the cursor. */
		cursor: url("/cursor-lantern.svg") 21 3, auto;
	}

	/* keep the lantern on clickable things too (they'd default to a pointer) */
	a,
	button,
	[role="button"] {
		cursor: url("/cursor-lantern.svg") 21 3, pointer;
	}

	::selection {
		background: var(--color-accent-deep);
		color: var(--text-primary);
	}

	/* floating control for the ambient soundtrack, bottom-right on every page */
	.sound-toggle {
		position: fixed;
		bottom: clamp(1rem, 3vw, 1.75rem);
		right: clamp(1rem, 3vw, 1.75rem);
		z-index: 50;
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		padding: 0;
		border-radius: 999px;
		color: var(--color-accent-bright);
		background: rgba(13, 15, 18, 0.55);
		border: 1px solid var(--color-border);
		-webkit-backdrop-filter: blur(6px);
		backdrop-filter: blur(6px);
		box-shadow: 0 4px 18px rgba(0, 0, 0, 0.4);
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			transform 0.15s ease;
	}
	.sound-toggle:hover {
		color: var(--text-primary);
		border-color: var(--color-accent-deep);
		transform: translateY(-1px);
	}
	.sound-toggle:focus-visible {
		outline: 2px solid var(--color-accent-bright);
		outline-offset: 3px;
	}
	.sound-toggle svg {
		width: 20px;
		height: 20px;
		display: block;
	}
	/* show the speaker-on glyph by default, the muted glyph when silenced */
	.sound-toggle .ico-off {
		display: none;
	}
	.sound-toggle.is-muted {
		color: var(--text-muted);
	}
	.sound-toggle.is-muted .ico-on {
		display: none;
	}
	.sound-toggle.is-muted .ico-off {
		display: block;
	}
</style>
