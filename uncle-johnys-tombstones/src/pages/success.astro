---
import Layout from "../layouts/Layout.astro";
import GroundFooter from "../components/GroundFooter.astro";

// Where the Wix-hosted checkout sends the buyer once payment is COMPLETE.
// It is wired up as `thankYouPageUrl` in /api/checkout. For an eCommerce
// checkout Wix appends `?orderId=<id>`, which we surface as a reference.
const orderId = Astro.url.searchParams.get("orderId");
---

<Layout>
  <section class="outcome outcome--success" aria-labelledby="outcome-title">
    <header class="topbar">
      <a class="back" href="/">&larr; Uncle Johny</a>
      <span class="mark">Uncle Johny&rsquo;s Tombstones</span>
    </header>

    <div class="panel">
      <p class="sigil" aria-hidden="true">&#10015;</p>

      <h1 id="outcome-title">It is <span class="done">done</span>.</h1>

      <p class="lede">
        Thank you, dear friend. Your tombstone is now in my care &mdash; I&rsquo;ll
        see it carved, and it will keep your name long after you&rsquo;re gone.
        Rest easy.
      </p>

      {
        orderId && (
          <p class="ref">
            Order reference
            <span class="ref-id">{orderId}</span>
          </p>
        )
      }

      <div class="actions">
        <a class="btn btn--primary" href="/shop">Back to the shop</a>
        <a class="btn btn--ghost" href="/">Return home</a>
      </div>
    </div>
  </section>

  <GroundFooter />
</Layout>

<style>
  .outcome {
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) 1.25rem clamp(4rem, 8vh, 6rem);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: radial-gradient(
      120% 70% at 50% -10%,
      var(--twilight-top) 0%,
      var(--color-bg) 40%,
      var(--color-void) 100%
    );
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .back {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }
  .back:hover {
    color: var(--color-accent-bright);
  }
  .mark {
    font-family: var(--font-creepy);
    font-size: 0.95rem;
    color: var(--text-muted);
    text-shadow: 0 0 16px rgba(45, 212, 191, 0.2);
  }

  .panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 42ch;
    margin: 0 auto;
  }

  /* success mark inside a soft cyan halo */
  .sigil {
    display: grid;
    place-items: center;
    width: clamp(64px, 12vw, 88px);
    height: clamp(64px, 12vw, 88px);
    margin: 0 0 clamp(1.25rem, 4vh, 2rem);
    border-radius: 999px;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    color: var(--color-void);
    background: var(--color-accent);
    box-shadow:
      0 0 0 1px rgba(94, 234, 212, 0.5),
      0 0 42px var(--color-accent-glow);
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5.5vw, 3.2rem);
    margin: 0 0 0.6rem;
    color: var(--text-primary);
  }
  .done {
    font-family: var(--font-creepy);
    font-weight: 400;
    color: var(--color-accent-bright);
    text-shadow: 0 0 22px var(--color-accent-glow);
  }

  .lede {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 0 clamp(1.5rem, 4vh, 2.25rem);
  }

  .ref {
    display: inline-flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0 0 clamp(1.75rem, 5vh, 2.5rem);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .ref-id {
    font-family: var(--font-body);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 3px;
    padding: 0.95em 2em;
    transition:
      background 0.2s ease,
      box-shadow 0.25s ease,
      transform 0.15s ease,
      color 0.2s ease;
  }
  .btn--primary {
    color: var(--color-void);
    background: var(--color-accent);
    box-shadow:
      0 0 0 1px rgba(94, 234, 212, 0.4),
      0 0 28px var(--color-accent-glow);
  }
  .btn--primary:hover {
    background: var(--color-accent-bright);
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px var(--color-accent-bright),
      0 0 42px var(--color-accent-glow);
  }
  .btn--ghost {
    color: var(--text-secondary);
    border: 1px solid var(--color-border);
  }
  .btn--ghost:hover {
    color: var(--text-primary);
    border-color: var(--color-accent-deep);
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-accent-bright);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: none;
    }
    .btn:hover {
      transform: none;
    }
  }
</style>
