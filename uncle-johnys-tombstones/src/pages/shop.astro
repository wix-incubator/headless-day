---
import Layout from "../layouts/Layout.astro";
import GroundFooter from "../components/GroundFooter.astro";
import { getProducts, getCurrency, type ShopProduct } from "../lib/shop";

let products: ShopProduct[] = [];
let currency = "USD";
let loadError = false;

try {
  [products, currency] = await Promise.all([getProducts(), getCurrency()]);
} catch (e) {
  loadError = true;
}

const priceFmt = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency,
});
---

<Layout>
  <section class="shop" aria-labelledby="shop-title">
    <header class="topbar">
      <a class="back" href="/" data-evt="Nav: Home">&larr; Uncle Johny</a>
      <span class="mark">Uncle Johny&rsquo;s Tombstones</span>
    </header>

    <h1 id="shop-title">Choose your Tombstone</h1>
    <p class="lede">
      Each one carved to outlast you. Pick the stone that will keep your name.
    </p>

    {
      loadError && (
        <p class="notice" role="alert">
          The catalogue couldn&rsquo;t be reached right now. Please try again in
          a moment.
        </p>
      )
    }

    {
      !loadError && products.length === 0 && (
        <p class="notice">No tombstones are on offer just yet.</p>
      )
    }

    {
      products.length > 0 && (
        <ul class="grid" role="list">
          {products.map((p) => (
            <li>
              <a
                class="card"
                href={`/product/${p.id}`}
                data-evt="View Product"
                data-evt-props={JSON.stringify({
                  product: p.name,
                  price: Number(p.price) || 0,
                })}
              >
                {p.imageUrl ? (
                  <img
                    class="thumb"
                    src={p.imageUrl}
                    alt={p.imageAlt}
                    loading="lazy"
                  />
                ) : (
                  <span class="thumb thumb-empty" aria-hidden="true" />
                )}
                <span class="price">
                  <span class="amount">
                    {priceFmt.format(Number(p.price))}
                  </span>
                  <span class="currency">{currency}</span>
                </span>
                <h2 class="name">{p.name}</h2>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <GroundFooter />
</Layout>

<style>
  .shop {
    /* max-width: 960px; */
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) 1.25rem clamp(4rem, 8vh, 6rem);
    min-height: 100svh;
    background: radial-gradient(
      120% 70% at 50% -10%,
      var(--twilight-top) 0%,
      var(--color-bg) 40%,
      var(--color-void) 100%
    );
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .back {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }
  .back:hover {
    color: var(--color-toxic-bright);
  }
  .mark {
    font-family: var(--font-creepy);
    font-size: 0.95rem;
    color: var(--text-muted);
    text-shadow: 0 0 16px rgba(57, 255, 20, 0.2);
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.9rem, 5vw, 3rem);
    margin: clamp(1.5rem, 4vh, 2.5rem) 0 0.4rem;
    color: var(--text-primary);
  }
  .lede {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2.4vw, 1.35rem);
    color: var(--text-secondary);
    margin: 0 0 clamp(2rem, 5vh, 3rem);
    max-width: 46ch;
  }

  .notice {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--text-secondary);
    padding: 2rem 0;
  }

  /* two-column grid; each tile is a third of the viewport tall */
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }
  .grid > li {
    list-style: none;
  }

  /* the whole card is the link to the product page */
  .card {
    position: relative;
    display: block;
    height: calc(100svh / 2);
    min-height: 280px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    background: var(--color-void);
    transition:
      border-color 0.25s ease,
      box-shadow 0.3s ease,
      transform 0.25s ease;
  }
  .card:hover {
    border-color: var(--color-toxic);
    box-shadow:
      0 20px 44px rgba(0, 0, 0, 0.55),
      0 0 24px var(--color-toxic-glow);
    transform: translateY(-3px);
  }
  .card:focus-visible {
    outline: 2px solid var(--color-toxic-bright);
    outline-offset: 3px;
  }

  .thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card:hover .thumb {
    transform: scale(1.06);
  }
  .thumb-empty {
    background: repeating-linear-gradient(
      45deg,
      var(--color-overlay),
      var(--color-overlay) 10px,
      var(--color-surface) 10px,
      var(--color-surface) 20px
    );
  }

  /* darkening at the foot so the title stays readable over any image */
  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 7, 10, 0.85) 0%,
      rgba(5, 7, 10, 0.35) 30%,
      transparent 60%
    );
    pointer-events: none;
    transition: background 0.25s ease;
  }
  .card:hover::after {
    background: linear-gradient(
      to top,
      rgba(5, 7, 10, 0.9) 0%,
      rgba(5, 7, 10, 0.45) 45%,
      rgba(5, 7, 10, 0.1) 100%
    );
  }

  /* title pinned to the bottom of the card, always visible */
  .name {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    margin: 0;
    padding: clamp(0.9rem, 2.4vw, 1.35rem);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.1rem, 2.4vw, 1.6rem);
    line-height: 1.2;
    color: var(--text-primary);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.85);
  }

  /* price tag, hidden until the card is hovered */
  .price {
    position: absolute;
    top: clamp(0.75rem, 2vw, 1.1rem);
    right: clamp(0.75rem, 2vw, 1.1rem);
    z-index: 3;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.5em 0.85em;
    border-radius: 999px;
    background: var(--color-toxic);
    color: var(--color-void);
    box-shadow: 0 0 22px var(--color-toxic-glow);
    pointer-events: none;
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
  .card:hover .price,
  .card:focus-visible .price {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .amount {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.95rem, 1.8vw, 1.2rem);
  }
  .currency {
    font-family: var(--font-display);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  /* touch devices have no hover — always show the price there */
  @media (hover: none) {
    .price {
      opacity: 1;
      transform: none;
    }
  }

  /* very narrow screens: fall back to a single column */
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .thumb,
    .price,
    .card::after {
      transition: none;
    }
    .card:hover,
    .card:hover .thumb {
      transform: none;
    }
  }
</style>
