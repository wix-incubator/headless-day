      }
      .glass-cell:hover { background: rgba(244, 240, 234, 0.06); border-color: rgba(200, 152, 72, 0.35); transform: translateY(-3px); }
      .amenity-icon { width: 30px; height: 30px; color: var(--accent); margin-bottom: 18px; }
      .amenity-icon svg { width: 100%; height: 100%; }
      .amenity-title { font-family: var(--heading); font-weight: 400; font-size: 19px; margin-bottom: 9px; }
      .amenity-desc { font-size: 13px; line-height: 1.65; color: var(--concrete-dim); }

      .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 220px; gap: 14px; margin-top: 44px; }
      @media (max-width: 900px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 180px; } }
      .gallery-item { overflow: hidden; position: relative; }
      .gallery-item.tall { grid-row: span 2; }
      .gallery-item img {
        width: 100%; height: 100%; object-fit: cover; display: block;
        transition: transform 0.8s cubic-bezier(0.2, 0.6, 0.2, 1); will-change: transform;
      }
      .gallery-item:hover img { transform: scale(1.03); }

      /* faq */
      .faq-list { margin-top: 40px; border-top: 1px solid rgba(244, 240, 234, 0.08); }
      .faq-item { border-bottom: 1px solid rgba(244, 240, 234, 0.08); }
      .faq-item summary {
        display: flex; align-items: baseline; justify-content: space-between; gap: 18px;
        padding: 22px 4px; cursor: pointer; list-style: none;
      }
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item summary h3 {
        font-family: var(--heading); font-weight: 400; font-size: 18px; line-height: 1.4;
      }
      .faq-mark { color: var(--accent); font-size: 20px; flex: none; transition: transform 0.3s ease; }
      .faq-item[open] .faq-mark { transform: rotate(45deg); }
      .faq-item p {
        padding: 0 4px 24px; max-width: 60ch;
        color: var(--warm-white-dim); font-size: 15px; line-height: 1.75;
      }
      @media (max-width: 640px) { .faq-item summary h3 { font-size: 16px; } .faq-item p { font-size: 16px; } }

      /* form */
      .glass-form {
        margin-top: 46px; padding: 40px;
        background: rgba(244, 240, 234, 0.03); border: 1px solid rgba(244, 240, 234, 0.06);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      }
      @media (max-width: 640px) { .glass-form { padding: 26px 20px; } }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
      @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
      .glass-form label {
        display: flex; flex-direction: column; gap: 8px;
        font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--concrete-dim);
      }
      .glass-form label.full { margin-bottom: 18px; }
      .glass-form input, .glass-form select, .glass-form textarea {
        background: rgba(14, 13, 12, 0.5); border: 1px solid rgba(244, 240, 234, 0.12);
        color: var(--warm-white); font-family: var(--body); font-size: 15px; font-weight: 300;
        padding: 13px 14px; outline: none; border-radius: 0;
        transition: border-color 0.3s; width: 100%;
        color-scheme: dark;
      }
      .glass-form input:focus, .glass-form select:focus, .glass-form textarea:focus { border-color: var(--accent); }
      .form-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-top: 6px; }
      @media (max-width: 640px) {
        .form-actions { flex-direction: column; }
        .form-actions .btn-primary, .form-actions .btn-ghost { width: 100%; text-align: center; }
      }
      .btn-primary {
        background: var(--accent); color: var(--ink); border: 1px solid var(--accent);
        font-family: var(--body); font-weight: 500; font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
        padding: 16px 34px; cursor: none; transition: box-shadow 0.3s, transform 0.3s;
      }
      .btn-primary:hover { box-shadow: 0 0 28px var(--accent-glow); transform: translateY(-1px); }
      .btn-primary:disabled { opacity: 0.55; box-shadow: none; transform: none; }
      .btn-ghost {
        color: var(--warm-white-dim); border: 1px solid rgba(244, 240, 234, 0.2);
        font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; text-decoration: none;
        padding: 15px 30px; transition: border-color 0.3s, color 0.3s;
      }
      .btn-ghost:hover { border-color: var(--accent); color: var(--warm-white); }
      .form-status { margin-top: 16px; font-size: 13px; letter-spacing: 0.04em; color: var(--concrete-dim); min-height: 18px; }
      .form-status.ok { color: #9ec89a; }
      .form-status.err { color: #d49a9a; }

      /* mobile perf: backdrop-filter and the grain layer are GPU-heavy on phones */
      @media (max-width: 900px) {
        .grain { display: none; }
        .stat-bar, .glass-cell, .glass-form {
          backdrop-filter: none; -webkit-backdrop-filter: none;
          background: rgba(20, 18, 16, 0.72);
        }
        .static-section { padding: 90px 0; }
      }

      /* mobile readability: the tracked micro-labels are too small on phones */
      @media (max-width: 900px) {
        .overline { font-size: 12px; letter-spacing: 0.22em; }
        .hero-tag { font-size: 16px; }
        .section-body { font-size: 16px; }
        .stat-label { font-size: 10px; letter-spacing: 0.18em; }
        .attribution { font-size: 12px; letter-spacing: 0.22em; }
        .feature-list li { font-size: 15px; }
        .amenity-desc { font-size: 14px; }
        .glass-form label { font-size: 11px; letter-spacing: 0.18em; }
        .form-status { font-size: 14px; }
        .btn-primary, .btn-ghost { font-size: 12px; letter-spacing: 0.2em; }
        .loader-sub { font-size: 11px; }
        .loader-pct { font-size: 12px; }
        .footer-legal { font-size: 12px; }
        .footer-brand { font-size: 16px; }
      }

      footer { background: #131110; padding: 60px 0 46px; text-align: center; }
      .footer-brand { font-family: var(--heading); letter-spacing: 0.3em; text-transform: uppercase; font-size: 15px; color: var(--warm-white-dim); }
      .footer-legal { margin-top: 12px; font-size: 11px; color: var(--concrete-dim); letter-spacing: 0.06em; }

      /* reduced motion */
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .anim-zone { height: auto; }
        .sticky-stage { position: relative; height: auto; min-height: 100vh; padding: 12vh 0; display: flex; flex-direction: column; gap: 10vh; justify-content: center; }
        .zone-canvas { position: absolute; height: 100%; }
        .overlay { position: relative; opacity: 1; visibility: visible; filter: none; transform: none; top: auto; margin: 0 6%; }
        .overlay-center.visible, .overlay-center { transform: none; }
        .reveal { opacity: 1; transform: none; }
        #particles, #cursor-dot, #cursor-ring { display: none; }
        body { cursor: auto; }
      }
    </style>

    <script>
      // ===== Villa Serena — scroll engine =====
      const REDUCED = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const IS_MOBILE = window.matchMedia("(max-width: 900px), (hover: none)").matches;
      const FRAME_COUNT = 120;
      // mobile: snappier follow, gentler dwell, and a 1x canvas (mobile frames are 960x540 anyway)
      const LERP_FACTOR = IS_MOBILE ? 0.16 : 0.13;
      const DWELL_WIDTH = 0.045;
      const DWELL_PEAK = IS_MOBILE ? 2.2 : 2.8;
      const REMAP_N = 2000;
      // backing store above ~1.5x buys nothing (720p source) and doubles per-frame draw cost on retina
      const DPR = IS_MOBILE ? 1 : Math.min(window.devicePixelRatio || 1, 1.5);
      const DIR = IS_MOBILE ? "mobile" : "desktop";

      const framePath = (zone: number, i: number) =>
        `/frames/zone${zone}/${DIR}/frame-${String(i + 1).padStart(4, "0")}.webp`;

      // ---- dwell remap: gaussian density peaks at content stops ----
      function buildRemap(centers: number[]) {
        const density = (t: number) => {
          let d = 1;
          for (const c of centers) {
            const x = (t - c) / DWELL_WIDTH;
            d += DWELL_PEAK * Math.exp(-x * x);
          }
          return d;
        };
        const cum = new Float64Array(REMAP_N + 1);
        for (let i = 1; i <= REMAP_N; i++) cum[i] = cum[i - 1] + density((i - 0.5) / REMAP_N);
        const total = cum[REMAP_N];
        // invert: scroll fraction -> effective progress
        return (t: number) => {
          if (t <= 0) return 0;
          if (t >= 1) return 1;
          const target = t * total;
          let lo = 0, hi = REMAP_N;
          while (lo < hi) {
            const mid = (lo + hi) >> 1;
            if (cum[mid] < target) lo = mid + 1; else hi = mid;
          }
          const c1 = cum[lo - 1], c2 = cum[lo];
          const f = c2 > c1 ? (target - c1) / (c2 - c1) : 0;
          return (lo - 1 + f) / REMAP_N;
        };
      }

      // ---- per-zone animator ----
      class Zone {
        el: HTMLElement;
        canvas: HTMLCanvasElement;
        ctx: CanvasRenderingContext2D;
        overlays: { el: HTMLElement; show: number; hide: number }[];
        frames: (ImageBitmap | HTMLImageElement | null)[];
        zone: number;
        remap: (t: number) => number;
        current = 0;
        lastDrawn = -1;
        loaded = 0;
        started = false;
        isOnscreen = false;
        onProgress: ((loaded: number, total: number) => void) | null = null;

        constructor(el: HTMLElement, dwellCenters: number[]) {
          this.el = el;
          this.zone = Number(el.dataset.zone);
          this.canvas = el.querySelector(".zone-canvas") as HTMLCanvasElement;
          this.ctx = this.canvas.getContext("2d") as CanvasRenderingContext2D;
          this.frames = new Array(FRAME_COUNT).fill(null);
          this.remap = buildRemap(dwellCenters);
          this.overlays = Array.from(el.querySelectorAll(".overlay")).map((o) => ({
            el: o as HTMLElement,
            show: parseFloat((o as HTMLElement).dataset.show || "0"),
            hide: parseFloat((o as HTMLElement).dataset.hide || "1"),
          }));
          this.resize();
          window.addEventListener("resize", () => {
            // ignore the small height jitter from the mobile URL bar — a real resize changes width
            const w = Math.round(this.canvas.clientWidth * DPR);
            const h = Math.round(this.canvas.clientHeight * DPR);
            if (w === this.canvas.width && Math.abs(h - this.canvas.height) < 160 * DPR) return;
            this.resize();
            this.lastDrawn = -1;
          });
        }

        resize() {
          const w = this.canvas.clientWidth, h = this.canvas.clientHeight;
          this.canvas.width = Math.round(w * DPR);
          this.canvas.height = Math.round(h * DPR);
          // setting width resets context state — reapply the upscale filter.
          // "high" is a CPU multi-pass resample: ~66ms/draw at desktop size vs
          // 0.37ms for "medium" (GPU bilinear) — it caused a visible hitch on
          // every frame advance, felt as scroll lag
          this.ctx.imageSmoothingEnabled = true;
          this.ctx.imageSmoothingQuality = "medium";
        }

        async fetchFrame(i: number): Promise<void> {
          const res = await fetch(framePath(this.zone, i));
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const blob = await res.blob();
          this.frames[i] = typeof createImageBitmap === "function"
            ? await createImageBitmap(blob)
            : await new Promise<HTMLImageElement>((resolve, reject) => {
                const img = new Image();
                const url = URL.createObjectURL(blob);
                img.onload = () => { URL.revokeObjectURL(url); resolve(img); };
                img.onerror = (e) => { URL.revokeObjectURL(url); reject(e); };
                img.src = url;
              });
        }

        async loadFrame(i: number): Promise<void> {
          if (this.frames[i]) return;
          try {
            await this.fetchFrame(i);
          } catch {
            // one retry — the CDN occasionally 500s on cold-cache fills right after a release
            try {
              await new Promise((r) => setTimeout(r, 800));
              await this.fetchFrame(i);
            } catch {
              this.frames[i] = null; // nearest-neighbor fallback covers gaps
            }
          }
          this.loaded++;
          this.onProgress?.(this.loaded, FRAME_COUNT);
        }

        async load(criticalDone?: () => void) {
          if (this.started) return;
          this.started = true;
          // first frame gets the network to itself — earliest possible paint on slow connections
          await this.loadFrame(0);
          // critical pass: every 4th frame
          const critical: number[] = [];
          for (let i = 4; i < FRAME_COUNT; i += 4) critical.push(i);
          await Promise.all(critical.map((i) => this.loadFrame(i)));
          this.lastDrawn = -1; // force first paint
          criticalDone?.();
          // fill remaining in small batches
          const rest: number[] = [];
          for (let i = 0; i < FRAME_COUNT; i++) if (!this.frames[i]) rest.push(i);
          const BATCH = 10;
          for (let b = 0; b < rest.length; b += BATCH) {
            await Promise.all(rest.slice(b, b + BATCH).map((i) => this.loadFrame(i)));
          }
        }

        nearestFrame(i: number) {
          if (this.frames[i]) return this.frames[i];
          for (let d = 1; d < FRAME_COUNT; d++) {
            if (this.frames[i - d]) return this.frames[i - d];
            if (this.frames[i + d]) return this.frames[i + d];
          }
          return null;
        }

        draw(index: number): boolean {
          const img = this.nearestFrame(index);
          if (!img) return false;
          const cw = this.canvas.width, ch = this.canvas.height;
          const iw = (img as ImageBitmap).width, ih = (img as ImageBitmap).height;
          const scale = Math.max(cw / iw, ch / ih);
          const dw = iw * scale, dh = ih * scale;
          this.ctx.drawImage(img as CanvasImageSource, (cw - dw) / 2, (ch - dh) / 2, dw, dh);
          return true;
        }

        tick() {
          // one layout read per zone per frame: onscreen + progress from the same rect
          const rect = this.el.getBoundingClientRect();
          this.isOnscreen = rect.bottom > 0 && rect.top < window.innerHeight;
          if (!this.isOnscreen) return;
          const total = rect.height - window.innerHeight;
          const raw = total > 0 ? Math.max(0, Math.min(1, -rect.top / total)) : 0;
          const eff = this.remap(raw);
          const target = eff * (FRAME_COUNT - 1);
          this.current += (target - this.current) * LERP_FACTOR;
          if (Math.abs(target - this.current) < 0.4) this.current = target;
          const idx = Math.round(this.current);
          // only mark drawn when a frame actually painted — otherwise retry every
          // tick, so the film appears the moment the first frame arrives
          if (idx !== this.lastDrawn && this.draw(idx)) {
            this.lastDrawn = idx;
          }
          for (const o of this.overlays) {
            o.el.classList.toggle("visible", raw >= o.show && raw <= o.hide);
          }
        }
      }

      const zone1El = document.getElementById("zone1")!;
      // dwell stops: exterior, living room, kitchen, bedroom (motion-equalized timeline)
      const z1 = new Zone(zone1El, [0.05, 0.38, 0.6, 0.88]);

      // ---- loader (tracks zone 1 critical set) ----
      const loader = document.getElementById("loader")!;
      const fill = document.getElementById("loader-fill")!;
      const pct = document.getElementById("loader-pct")!;
      const CRITICAL_TOTAL = Math.ceil(FRAME_COUNT / 4);
      // reveal at 75% of the critical set — waiting for the last parallel
      // stragglers (or a 500-retry) parks the bar near the end for seconds
      // while the film underneath is already viewable
      const REVEAL_AT = Math.ceil(CRITICAL_TOTAL * 0.75);
      let loaderHidden = false;
      z1.onProgress = (loaded) => {
        if (loaderHidden) return;
        const p = Math.min(100, Math.round((loaded / REVEAL_AT) * 100));
        fill.style.width = p + "%";
        pct.textContent = p + "%";
        if (loaded >= REVEAL_AT && z1.frames[0]) hideLoader();
      };
      function hideLoader() {
        if (loaderHidden) return;
        loaderHidden = true;
        fill.style.width = "100%";
        pct.textContent = "100%";
        setTimeout(() => loader.classList.add("done"), 150);
        setTimeout(() => loader.remove(), 1200);
      }

      if (REDUCED) {
        // static experience: first frame, everything visible
        z1.loadFrame(0).then(() => { z1.draw(0); hideLoader(); });
        document.querySelectorAll(".overlay").forEach((o) => o.classList.add("visible"));
        document.querySelectorAll(".reveal").forEach((o) => o.classList.add("in"));
      } else {
        z1.load(hideLoader);
        // safety: hide loader even if a frame stalls
        setTimeout(hideLoader, 9000);
      }

      // ---- main loop ----
      const tint = document.getElementById("tint")!;
      let tintOn = false;
      function loop() {
        z1.tick();
        const wantTint = z1.isOnscreen;
        if (wantTint !== tintOn) {
          tintOn = wantTint;
          tint.style.opacity = wantTint ? "1" : "0";
        }
        requestAnimationFrame(loop);
      }
      if (!REDUCED) requestAnimationFrame(loop);

      // ---- letter split ----
      document.querySelectorAll("[data-split]").forEach((el) => {
        const text = el.textContent || "";
        el.textContent = "";
        // aria-label is prohibited on a generic span — expose the text via an sr-only node instead
        const sr = document.createElement("span");
        sr.className = "sr-only";
        sr.textContent = text;
        el.appendChild(sr);
        // group letters into word spans so lines can only break at spaces, never mid-word
        let ci = 0;
        text.split(" ").forEach((word, wi, words) => {
          const w = document.createElement("span");
          w.className = "word";
          w.setAttribute("aria-hidden", "true");
          word.split("").forEach((ch) => {
            const span = document.createElement("span");
            span.className = "ch";
            span.textContent = ch;
            span.style.transitionDelay = `${ci * 35}ms`;
            ci++;
            w.appendChild(span);
          });
          el.appendChild(w);
          if (wi < words.length - 1) {
            el.appendChild(document.createTextNode(" "));
            ci++;
          }
        });
      });
      setTimeout(() => document.querySelectorAll("[data-split]").forEach((el) => el.classList.add("split-done")), 600);

      // ---- stat counters ----
      function animateCounters() {
        document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
          const raw = el.dataset.count || "";
          const m = raw.match(/^([\d.]+)(.*)$/);
          if (!m) return;
          const target = parseFloat(m[1]);
          const suffix = m[2];
          const decimals = (m[1].split(".")[1] || "").length;
          const t0 = performance.now();
          const dur = 1500;
          const step = (t: number) => {
            const p = Math.min(1, (t - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = (target * eased).toFixed(decimals) + suffix;
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        });
      }
      if (!REDUCED) setTimeout(animateCounters, 900);

      // ---- particles ----
      if (!REDUCED && !IS_MOBILE) {
        const pc = document.getElementById("particles") as HTMLCanvasElement;
        const pctx = pc.getContext("2d")!;
        let pw = (pc.width = window.innerWidth);
        let ph = (pc.height = window.innerHeight);
        window.addEventListener("resize", () => { pw = pc.width = window.innerWidth; ph = pc.height = window.innerHeight; });
        const dots = Array.from({ length: 36 }, () => ({
          x: Math.random() * pw, y: Math.random() * ph,
          r: 0.3 + Math.random() * 1.5,
          vx: (Math.random() - 0.5) * 0.15, vy: (Math.random() - 0.5) * 0.12,
          a: 0.05 + Math.random() * 0.3,
        }));
        (function drift() {
          pctx.clearRect(0, 0, pw, ph);
          for (const d of dots) {
            d.x = (d.x + d.vx + pw) % pw;
            d.y = (d.y + d.vy + ph) % ph;
            pctx.beginPath();
            pctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
            pctx.fillStyle = `rgba(244, 240, 234, ${d.a})`;
            pctx.fill();
          }
          requestAnimationFrame(drift);
        })();
      }

      // ---- custom cursor ----
      if (!IS_MOBILE && !REDUCED) {
        const dot = document.getElementById("cursor-dot")!;
        const ring = document.getElementById("cursor-ring")!;
        let mx = -100, my = -100, rx = -100, ry = -100;
        window.addEventListener("mousemove", (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.left = mx + "px"; dot.style.top = my + "px";
        });
        (function follow() {
          rx += (mx - rx) * 0.15; ry += (my - ry) * 0.15;
          ring.style.left = rx + "px"; ring.style.top = ry + "px";
          requestAnimationFrame(follow);
        })();
        document.querySelectorAll("a, button, .glass-cell, input, select, textarea, .gallery-item").forEach((el) => {
          el.addEventListener("mouseenter", () => ring.classList.add("hovering"));
          el.addEventListener("mouseleave", () => ring.classList.remove("hovering"));
        });
      }

      // ---- chapter markers ----
      const chapterBtns = Array.from(document.querySelectorAll<HTMLElement>("#chapters button"));
      const chapterTargets = () => {
        const z1Top = zone1El.offsetTop;
        const runway = zone1El.offsetHeight - window.innerHeight;
        return [
          z1Top,
          z1Top + runway * 0.38, // living room dwell
          z1Top + runway * 0.6, // kitchen dwell
          (document.getElementById("amenities") as HTMLElement).offsetTop - 80,
          (document.getElementById("gallery") as HTMLElement).offsetTop - 80,
          (document.getElementById("reserve") as HTMLElement).offsetTop - 80,
        ];
      };
      // cache section offsets — recomputing 6 offsetTops on every scroll event forces layout
      let chapterPositions = chapterTargets();
      const refreshChapters = () => { chapterPositions = chapterTargets(); };
      chapterBtns.forEach((btn, i) => {
        btn.addEventListener("click", () => {
          refreshChapters(); // layout may have shifted since the cache was taken
          window.scrollTo({ top: chapterPositions[i], behavior: REDUCED ? "auto" : "smooth" });
        });
      });
      function updateChapters() {
        const pos = window.scrollY + window.innerHeight * 0.4;
        let active = 0;
        chapterPositions.forEach((t, i) => { if (pos >= t) active = i; });
        chapterBtns.forEach((b, i) => b.classList.toggle("active", i === active));
      }
      // CSS hides #chapters below 900px by width alone — gate on the same query, not IS_MOBILE
      if (window.matchMedia("(min-width: 901px)").matches) {
        // the async font swap reflows sections without firing a resize event
        document.fonts?.ready.then(() => { refreshChapters(); updateChapters(); });
        window.addEventListener("resize", refreshChapters);
        window.addEventListener("scroll", updateChapters, { passive: true });
        updateChapters();
      }

      // ---- reveal on scroll + gallery parallax ----
      const revealObs = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("in"); }),
        { threshold: 0.12 }
      );
      document.querySelectorAll(".reveal").forEach((el) => revealObs.observe(el));

      if (!REDUCED && !IS_MOBILE) {
        const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));
        (function parallax() {
          const vh = window.innerHeight;
          for (const el of parallaxEls) {
            const rect = el.getBoundingClientRect();
            if (rect.bottom < 0 || rect.top > vh) continue;
            const centerOffset = (rect.top + rect.height / 2 - vh / 2) / vh;
            const depth = parseFloat(el.dataset.parallax || "0");
            const img = el.querySelector("img");
            if (img) img.style.transform = `translateY(${centerOffset * depth}px)`;
          }
          requestAnimationFrame(parallax);
        })();
      }

      // ---- booking inquiry form ----
      const form = document.getElementById("inquiry-form") as HTMLFormElement;
      const status = document.getElementById("form-status")!;
      const submitBtn = document.getElementById("inquiry-submit") as HTMLButtonElement;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.className = "form-status";
        if (!form.reportValidity()) return;
        const data = Object.fromEntries(new FormData(form));
        submitBtn.disabled = true;
        status.textContent = "Sending…";
        try {
          const res = await fetch("/api/inquiry", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
          const body = await res.json();
          if (res.ok && body.ok) {
            status.textContent = "Thank you — we received your inquiry and will be in touch within a day.";
            status.classList.add("ok");
            form.reset();
          } else {
            throw new Error(body.error || "Submission failed");
          }
        } catch (err) {
          status.textContent = err instanceof Error ? err.message : "Something went wrong — please try again.";
          status.classList.add("err");
        } finally {
          submitBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
