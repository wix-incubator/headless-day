      .feature-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); flex: none; box-shadow: 0 0 8px var(--accent-glow); }

      /* static sections */
      .static-section { position: relative; padding: 140px 0; background: var(--ink); z-index: 20; }
      .container { width: min(1180px, 88vw); margin: 0 auto; }
      .container.narrow { width: min(760px, 88vw); }

      .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.9s ease, transform 0.9s ease; }
      .reveal.in { opacity: 1; transform: translateY(0); }

      .amenity-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 44px; }
      @media (max-width: 1000px) { .amenity-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { .amenity-grid { grid-template-columns: 1fr; } }
      .glass-cell {
        background: rgba(244, 240, 234, 0.03); border: 1px solid rgba(244, 240, 234, 0.06);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
