      .attribution { font-style: normal; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--concrete-dim); }

      .section-title { font-family: var(--heading); font-weight: 300; font-size: clamp(30px, 3.6vw, 52px); line-height: 1.12; margin-bottom: 18px; }
      .section-title.big { font-size: clamp(36px, 4.6vw, 64px); }
      .section-title.centered, .section-body.centered { text-align: center; margin-left: auto; margin-right: auto; }
      .section-body { color: var(--warm-white-dim); font-size: clamp(15px, 1.3vw, 17px); line-height: 1.75; max-width: 50ch; }

      .feature-list { list-style: none; margin-top: 26px; }
      .feature-list li {
        display: flex; align-items: center; gap: 14px; padding: 13px 0;
