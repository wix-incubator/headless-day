---
// Reusable currency note: site shows ₴, checkout charges $ (provider constraint).
import { UAH_PER_USD } from "../lib/pricing";
interface Props { class?: string; }
const { class: className = "" } = Astro.props;
---
<div class:list={["max-w-prose rounded-sm border border-rule bg-paper-warm px-5 py-4 flex gap-3 items-start", className]}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.6" class="shrink-0 mt-0.5" aria-hidden="true">
    <circle cx="12" cy="12" r="9" /><path d="M12 11v5" /><path d="M12 8h.01" />
  </svg>
  <p class="text-sm text-mute leading-relaxed">
    Prices across the site are shown in Ukrainian hryvnia (<span class="text-ink">₴</span>).
    Payment is processed in US dollars, so the total at checkout appears in <span class="text-ink">$</span> —
    converted at about <span class="text-ink">₴{UAH_PER_USD} = $1</span> (e.g. a ₴1,950 seat is roughly ${(1950 / UAH_PER_USD).toFixed(2)}).
  </p>
</div>
