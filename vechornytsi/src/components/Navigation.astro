---
import CartBadge from "./CartBadge.astro";
---
<header class="site-nav" transition:persist="site-nav">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between gap-6 py-4">
    <a href="/" class="font-display text-lg tracking-tight">Vechornytsi</a>

    <input type="checkbox" id="nav-toggle" class="peer hidden" aria-hidden="true" />
    <label
      for="nav-toggle"
      class="md:hidden inline-flex flex-col gap-[5px] cursor-pointer"
      aria-label="Toggle navigation"
    >
      <span class="block h-[2px] w-6 bg-ink"></span>
      <span class="block h-[2px] w-6 bg-ink"></span>
      <span class="block h-[2px] w-6 bg-ink"></span>
    </label>

    <div
      class="hidden peer-checked:flex md:flex absolute md:static top-full left-0 right-0 md:right-auto
             flex-col md:flex-row gap-4 md:gap-6 items-start md:items-center
             bg-paper md:bg-transparent border-b md:border-0 border-rule px-6 md:px-0 py-4 md:py-0"
    >
      <ul class="flex flex-col md:flex-row gap-4 md:gap-6 items-start md:items-center">
        <li class="site-nav-item"><a href="/about">The Table</a></li>
        <li class="site-nav-item"><a href="/events">Upcoming Dinners</a></li>
        <li class="site-nav-item"><a href="/products">Shop</a></li>
        <li class="site-nav-item"><a href="/faq">FAQ</a></li>
        <li class="site-nav-item"><a href="/contact">Contact</a></li>
        <li class="site-nav-item"><a href="/account">My Account</a></li>
        <!-- nav:links -->
      </ul>
      <div class="nav-actions flex items-center gap-4">
        <a href="/events" class="btn-primary hidden md:inline-flex" style="padding: 0.5rem 1.1rem;">Reserve a seat</a>
        <CartBadge />
      </div>
    </div>
  </nav>
</header>
