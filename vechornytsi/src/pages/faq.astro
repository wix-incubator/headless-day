---
import Layout from "../layouts/Layout.astro";
import { getFaq } from "../lib/content";

const faq = await getFaq();

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};
---

<Layout
  title="FAQ"
  description="How reservations, the seven-course menu, wine pairings, private buyouts, and shipping work at Vechornytsi."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>

  <section class="max-w-6xl mx-auto px-6 pt-20 md:pt-24 pb-8">
    <div class="max-w-[52rem] reveal">
      <span class="kicker">Questions</span>
      <h1 class="font-display text-4xl md:text-6xl leading-[1.05] mt-4">Before you book</h1>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="container-reading flex flex-col divide-y divide-rule border-t border-rule">
      {faq.map((f, i) => (
        <details class="group py-5 reveal" open={i === 0}>
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
            <h2 class="font-display text-xl md:text-2xl text-ink">{f.question}</h2>
            <span class="text-accent text-2xl leading-none shrink-0 transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="text-mute leading-relaxed mt-3 max-w-prose">{f.answer}</p>
        </details>
      ))}
    </div>

    <div class="container-reading mt-14 accent-card p-7 reveal">
      <p class="font-display text-xl">Still have a question?</p>
      <p class="text-mute mt-1">Private dining, allergies, or anything else — write to us and we will reply within 48 hours.</p>
      <a href="/contact" class="btn-secondary mt-4 inline-flex">Contact us</a>
    </div>
  </section>
</Layout>
